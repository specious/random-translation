#!/usr/bin/env bash

# A small, portable utility that plucks out installed GNU gettext language translations on your system.
#
# Should work on macOS, Linux, and all *nix OS'es. By default it auto-builds a deep index on first run, then
# uses the index thereafter.
#
# Features
#  - discovery strategies: auto, quick, host-indexed, targeted, deep, index-only
#  - index behavior control: read, write, none
#  - index TTL and refresh (only when index-mode is read/write)
#  - flexible output (including json and yaml)
#  - color themes
#  - return N random msgstr strings (-n N)
#  - robust locale matching (es, es_ES, es-ES, es_ES.UTF-8)
#  - discovery roots override (--roots)
#  - direct .mo file input (--file)
#  - explicit extraction backend (--reader auto|msgunfmt|od)
#  - debug shows what each strategy and index decision is doing
#
# Exit codes
#  0 success
#  1 usage / argument error
#  2 missing tools for extraction
#  3 no matches found

set -euo pipefail

# Restore default SIGPIPE handling so the script exits when a downstream consumer closes the pipe
trap - PIPE 2>/dev/null || true

VERSION="1.4.0"

usage() {
  cat <<'EOF'
A small, portable utility that plucks out installed GNU gettext language translations on your system.

Usage: random-translation [options] LANGS...

  LANGS may be one or more language codes (space or comma separated).

  Examples:
    - Single codes: es tr el
    - Comma list: "es,el,tr"
    - Locale variant: es_ES

  Default behavior: auto deep-scan + index build on first run, index-based lookup thereafter.

Options
  --roots PATHS       Colon-separated roots to search (overrides default roots)
  --filter PATHS      Colon-separated prefix paths to restrict discovery (overrides LOCALE_DIRS and enables filtering)
  --strategy STR      Discovery strategy: auto|quick|host-indexed|targeted|deep|index-only
  --index-mode MODE   Index behavior: read|write|none
  --refresh           Force rebuild of the .mo list (applies when index-mode is write or when using transient list)
  --ttl SECS          Index TTL in seconds (default 3600)
  --debug             Print debug information showing what each strategy and index-mode decision does
  --meta              Include PO metadata (file header + msgctxt) in output
  --color WHEN        Colorize output: auto|always|never (default: auto)
  --no-color          Alias for --color never
  -n N                Print N random msgstr strings only (useful for screensavers)
  --output MODE       Output mode: human|raw|json|yaml|filename (default: human)
  --theme THEME       Color theme: aurora|cyberpunk|neon|sakura|classic|tokyonight|ocean|mars|jungle|phosphor (default: jungle)
  --index-stats       Print index stats (entries, age, size) then exit
  --index-init        Build the index (deep scan + write) and exit
  --version           Print version and exit
  --reader MODE       Extraction backend: auto|msgunfmt|od (default: auto)
  --file FILE         Read directly from this .mo file (bypasses index/discovery)
  --dry-run           Print the path that would be read and exit (alias for --output filename)
  -h, --help          Show this help
EOF
  exit 1
}

# Defaults
DEFAULT_LOCALE_DIRS="/usr/share/locale:/usr/local/share/locale:/usr/share/locale-langpack:/usr/lib/locale:/Library/Locale:/System/Library/Frameworks/Python.framework/Versions/Current/Resources/locale"
STRATEGY="auto"
STRATEGY_SET=0
LOCALE_DIRS="${LOCALE_DIRS:-$DEFAULT_LOCALE_DIRS}"
CACHE_MODE="read" # read | write | none; auto mode overrides as needed
CACHE_MODE_SET=0 # becomes 1 if user explicitly passed --index-mode
REFRESH=0
DEBUG=0
INCLUDE_META=0
COLOR_MODE="auto"
THEME="jungle"
N_STRINGS=0
OUTPUT_MODE="human" # human | raw | json | yaml | filename
INDEX_STATS=0
TTL=3600
ROOTS=""
FILTER_PATTERNS=""
LANGS=""
INDEX_INIT=0
MO_READER="auto"  # auto | msgunfmt | od
MO_FILE=""        # --file: read directly from this .mo path

# Verbose logging
_debug() { [ "$DEBUG" -eq 1 ] && printf 'DEBUG: %s\n' "$*" >&2 || true; }

# Print missing-argument error and show usage
_missing_arg() { echo "error: missing value for $1" >&2; usage; }

# Return the next argv value or call _missing_arg
_getval() {
  flag="$1"; val="${2-}"
  [ -n "${val-}" ] || _missing_arg "$flag"
  case "$val" in -*) _missing_arg "$flag" ;; esac
  printf '%s' "$val"
}

# If $1 looks like a flag or is empty, print "Available LIST" and exit; otherwise return $1 via _getval
# Usage: _check_list NEXTARG FLAG LIST — call before any $(...) subshell
_check_list() {
  case "${1-}" in ''|-*) printf 'Available %s\n' "$3"; exit 0 ;; esac
}

# Parse args (compact, safe under set -u)
while [ $# -gt 0 ]; do
  case "$1" in
    --roots)
      ROOTS="$(_getval --roots "${2-}")"; shift 2 ;;
    --strategy)
      _check_list "${2-}" --strategy 'strategies: auto, quick, host-indexed, targeted, deep, index-only'
      STRATEGY="$(_getval --strategy "${2-}")"; STRATEGY_SET=1; shift 2 ;;
    --index-mode)
      _check_list "${2-}" --index-mode 'index modes: read, write, none'
      CACHE_MODE="$(_getval --index-mode "${2-}")"; CACHE_MODE_SET=1; shift 2 ;;
    --color)
      _check_list "${2-}" --color 'color modes: auto, always, never'
      COLOR_MODE="$(_getval --color "${2-}")"; shift 2 ;;
    --theme)
      _check_list "${2-}" --theme 'themes: aurora, cyberpunk, neon, sakura, classic, tokyonight, ocean, mars, jungle, phosphor'
      THEME="$(_getval --theme "${2-}")"; shift 2 ;;
    --output)
      _check_list "${2-}" --output 'output modes: human, raw, json, yaml, filename'
      OUTPUT_MODE="$(_getval --output "${2-}")"; shift 2 ;;
    --reader)
      _check_list "${2-}" --reader 'reader modes: auto, msgunfmt, od'
      MO_READER="$(_getval --reader "${2-}")"; shift 2 ;;
    --ttl)          TTL="$(_getval --ttl "${2-}")"; shift 2 ;;
    --filter)       FILTER_PATTERNS="$(_getval --filter "${2-}")"; shift 2 ;;
    --file)         MO_FILE="$(_getval --file "${2-}")"; shift 2 ;;
    -n)             N_STRINGS="$(_getval -n "${2-}")"; shift 2 ;;
    --refresh)      REFRESH=1; shift ;;
    --debug)        DEBUG=1; shift ;;
    --meta)         INCLUDE_META=1; shift ;;
    --no-color)     COLOR_MODE="never"; shift ;;
    --dry-run)      OUTPUT_MODE="filename"; shift ;;
    --index-stats)  INDEX_STATS=1; shift ;;
    --index-init)   INDEX_INIT=1; shift ;;
    --version)      printf 'random-translation %s\n' "$VERSION"; exit 0 ;;
    -h|--help)      usage ;;
    --) shift;      break ;;
    -*)
      echo "error: unknown option: $1" >&2
      echo "Run --help for usage." >&2
      exit 1
      ;;
    *)
      LANGS="${LANGS} ${1}"; shift
      ;;
  esac
done

# Merge env var LANG_CODES if present
if [ -n "${LANG_CODES:-}" ]; then
  LANGS="${LANGS} ${LANG_CODES}"
fi

#
# Container-aware HOME / XDG bootstrap
#
# This block ensures the script behaves correctly when launched from GUI apps
# (screensavers, launchd, etc.) that may provide a minimal or containerized HOME.
# It:
#  - tries to resolve a real system home (getent/dscl/ /etc/passwd) when HOME is unset
#  - if HOME looks containerized, prefers the system home when available
#  - sets platform-appropriate XDG default (macOS -> ~/Library/Caches, others -> ~/.cache)
#  - leaves HOME alone if no better candidate is found
#

# helper: get home from system user DB (portable)
_get_system_home() {
  if command -v getent >/dev/null 2>&1; then
    getent passwd "$(id -u)" 2>/dev/null | cut -d: -f6 || true
    return
  fi

  if command -v dscl >/dev/null 2>&1; then
    user="$(id -un 2>/dev/null || true)"
    if [ -n "$user" ]; then
      dscl . -read "/Users/$user" NFSHomeDirectory 2>/dev/null | awk '{print $2}' || true
      return
    fi
  fi

  awk -F: -v uid="$(id -u)" '$3==uid {print $6; exit}' /etc/passwd 2>/dev/null || true
}

# If HOME unset, try to populate it from system DB or sensible fallback
if [ -z "${HOME:-}" ]; then
  syshome="$(_get_system_home)"
  HOME="${syshome:-}"
  if [ -z "$HOME" ]; then
    HOME="/Users/$(whoami 2>/dev/null || echo user)"
    [ -d "$HOME" ] || HOME="/home/$(whoami 2>/dev/null || echo user)"
  fi
  export HOME
fi

# If HOME looks like a container/sandbox path, try to prefer the system home
case "${HOME:-}" in
  */Library/Containers/*|*/Containers/*|*/private/var/containers/*|*/Library/Application\ Support/*)
    syshome="$(_get_system_home)"
    if [ -n "$syshome" ] && [ "$syshome" != "$HOME" ] && [ -d "$syshome" ]; then
      HOME="$syshome"
      export HOME
    fi
    ;;
esac

# Platform-aware default XDG cache location
OS="$(uname -s 2>/dev/null || echo unknown)"
case "$OS" in
  Darwin*) DEFAULT_XDG="$HOME/Library/Caches" ;;
  *)       DEFAULT_XDG="$HOME/.cache" ;;
esac

# Detect WSL: /proc/version contains "microsoft" or "WSL" on WSL1/WSL2
IS_WSL=0
if [ -f /proc/version ] && grep -qi 'microsoft\|wsl' /proc/version 2>/dev/null; then
  IS_WSL=1
  _debug "WSL detected"
fi
XDG_CACHE_HOME_USER_SET=0
if [ -n "${XDG_CACHE_HOME:-}" ]; then
  XDG_CACHE_HOME_USER_SET=1
fi
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-$DEFAULT_XDG}"

# Respect XDG_DATA_HOME for user-local data (common place for per-user locale files).
# Default per-spec: ${XDG_DATA_HOME:-$HOME/.local/share}
export XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
# Ensure LOCALE_DIRS includes $XDG_DATA_HOME/locale so per-user installs are discovered.
if [ -n "${XDG_DATA_HOME:-}" ]; then
  case ":${LOCALE_DIRS:-}:" in
    *":${XDG_DATA_HOME}/locale:") ;;
    *) LOCALE_DIRS="${LOCALE_DIRS}:${XDG_DATA_HOME}/locale" ;;
  esac
fi

_human_size() {
  local bytes="$1"
  awk -v b="${bytes}" 'BEGIN {
    split("B KiB MiB GiB TiB", u, " ")
    i = 1
    while (b >= 1024 && i < 5) { b /= 1024; i++ }
    if (i == 1) printf "%d %s", b, u[i]
    else printf "%.1f %s", b, u[i]
  }'
}

_human_age() {
  local secs="$1"
  awk -v s="${secs}" 'BEGIN {
    if (s < 0) s = 0
    if (s < 60) { printf "%d second%s", s, (s==1?"":"s") }
    else if (s < 3600) { m = int(s/60); printf "%d minute%s", m, (m==1?"":"s") }
    else if (s < 86400) { h = int(s/3600); printf "%d hour%s", h, (h==1?"":"s") }
    else { d = int(s/86400); printf "%d day%s", d, (d==1?"":"s") }
  }'
}

# Track explicit cache path overrides supplied by the environment.
CACHE_FILE_EXPLICIT=0
CACHE_DIR_EXPLICIT=0
[ "${CACHE_FILE+x}" = "x" ] && [ -n "${CACHE_FILE:-}" ] && CACHE_FILE_EXPLICIT=1
[ "${CACHE_DIR+x}" = "x" ] && [ -n "${CACHE_DIR:-}" ] && CACHE_DIR_EXPLICIT=1

# Ensure CACHE_DIR has a sensible default before any use (avoids set -u errors)
CACHE_DIR="${CACHE_DIR:-${XDG_CACHE_HOME}/random-translation}"
CACHE_FILE="${CACHE_FILE:-${CACHE_DIR}/mos.index}"

# Resolve cache file from multiple canonical locations (respect explicit overrides)
preferred_cache=""
if [ "$CACHE_FILE_EXPLICIT" -eq 1 ]; then
  preferred_cache="$CACHE_FILE"
elif [ "$CACHE_DIR_EXPLICIT" -eq 1 ]; then
  preferred_cache="${CACHE_DIR}/mos.index"
elif [ "$XDG_CACHE_HOME_USER_SET" -eq 1 ]; then
  CACHE_DIR="${XDG_CACHE_HOME}/random-translation"
  preferred_cache="${CACHE_DIR}/mos.index"
elif [ -n "${CACHE_FILE:-}" ] && [ -f "${CACHE_FILE}" ]; then
  preferred_cache="$CACHE_FILE"
fi

if [ -n "$preferred_cache" ]; then
  CACHE_FILE="$preferred_cache"
else
  CACHE_FILE=""

  for _c in \
      "${CACHE_FILE:-}" \
      "${CACHE_DIR:-}/mos.index" \
      "${XDG_CACHE_HOME:-$DEFAULT_XDG}/random-translation/mos.index" \
      "$HOME/Library/Caches/random-translation/mos.index" \
      "$HOME/.cache/random-translation/mos.index" \
      "/var/cache/random-translation/mos.index"; do
    [ -n "$_c" ] || continue
    if [ -f "$_c" ]; then
      CACHE_FILE="$_c"
      break
    fi
  done

  if [ -z "$CACHE_FILE" ]; then
    if [ "$OS" = "Darwin" ]; then
      CACHE_DIR="${CACHE_DIR:-${XDG_CACHE_HOME:-$HOME/Library/Caches}/random-translation}"
    else
      CACHE_DIR="${CACHE_DIR:-${XDG_CACHE_HOME:-$DEFAULT_XDG}/random-translation}"
    fi
    CACHE_FILE="${CACHE_FILE:-$CACHE_DIR/mos.index}"
    mkdir -p "$CACHE_DIR" 2>/dev/null || true
  fi
fi

# Ensure cache dir exists (no-op if already created); tolerate restricted envs
mkdir -p "${CACHE_DIR:-}" 2>/dev/null || true

# System-wide fallback
SYSTEM_CACHE="/var/cache/random-translation/mos.index"
if [ "$CACHE_FILE_EXPLICIT" -eq 0 ]; then
  if [ -z "${CACHE_FILE:-}" ] || [ ! -f "${CACHE_FILE:-}" ]; then
    if [ -f "$SYSTEM_CACHE" ]; then
      CACHE_FILE="$SYSTEM_CACHE"
    fi
  fi
fi

# Keep cache dir aligned with the chosen cache file path.
if [ -n "${CACHE_FILE:-}" ]; then
  CACHE_DIR="$(dirname "$CACHE_FILE")"
fi

_mtime_epoch() {
  local f="$1"
  if stat -f %m "$f" >/dev/null 2>&1; then
    stat -f %m "$f"
  else
    stat -c %Y "$f" 2>/dev/null || echo 0
  fi
}

_cache_index_present() {
  local d="$1" f
  for f in "$d"/mos.index.lang.*; do
    [ -f "$f" ] || continue
    case "$f" in
      *.count) continue ;;
    esac
    [ -s "$f" ] && return 0
  done
  return 1
}

_print_cache_missing() {
  local ctx="$1"
  echo "error: $ctx expects an existing index file: ${CACHE_FILE:-}" >&2
  if _cache_index_present "${CACHE_DIR:-}"; then
    echo "Found language index files in ${CACHE_DIR:-}, but master index file is missing." >&2
  fi
  echo "Hint: rebuild index with:" >&2
  echo "  ./random-translation --strategy host-indexed --index-mode write --refresh LANG" >&2
  echo "or:" >&2
  echo "  ./random-translation --strategy deep --index-mode write --refresh LANG" >&2
}

# _print_cache_stats: Display cache metrics with maximal portability
#
# Portability guarantees:
#   - Works on GNU/Linux, BSD (FreeBSD/OpenBSD/NetBSD), macOS/Darwin, WSL, Termux,
#     minimal containers, and any POSIX-ish environment with bash
#   - Graceful degradation when utilities are missing (du, stat, awk, etc.)
#   - Handles GNU vs BSD tool flag differences automatically via feature detection
#   - No external dependencies beyond core POSIX utilities + bash
#
# Size terminology:
#   - "Logical size" = byte count of file contents (what ls -l or stat reports)
#   - "Physical size" = actual disk blocks allocated (includes metadata, slack space)
#
# Units: IEC binary (KiB, MiB, GiB) for precision — 1 KiB = 1024 bytes
_print_cache_stats() {
  local count now mtime age idx_files=0 idx_total=0 f c size_bytes size_human
  local dir_logical_bytes dir_logical_human dir_physical_bytes dir_physical_human
  local has_gnu_du has_gnu_stat has_bsd_stat

  [ -f "${CACHE_FILE:-}" ] || return 1

  # --- Basic metadata (portable everywhere) ---
  mtime=$(_mtime_epoch "${CACHE_FILE}")
  now=$(date +%s)
  age=$((now - mtime))
  count=$(wc -l <"${CACHE_FILE}" 2>/dev/null | tr -d '[:space:]' || echo 0)

  size_bytes=$(wc -c <"${CACHE_FILE}" 2>/dev/null | tr -d '[:space:]' || echo 0)
  size_human=$(_human_size "$size_bytes")

  dir_logical_bytes=""
  dir_physical_bytes=""

  # --- Detect tool capabilities ---
  # GNU du can be identified by --version output (BSD du doesn't have this)
  has_gnu_du=0
  if command -v du >/dev/null 2>&1; then
    if du --version 2>/dev/null | grep -q 'GNU coreutils'; then
      has_gnu_du=1
    fi
  fi

  # Stat detection
  has_gnu_stat=0
  has_bsd_stat=0
  if command -v stat >/dev/null 2>&1; then
    if stat -c %s "${CACHE_FILE}" >/dev/null 2>&1; then
      has_gnu_stat=1
    elif stat -f %z "${CACHE_FILE}" >/dev/null 2>&1; then
      has_bsd_stat=1
    fi
  fi

  # --- Calculate logical size (apparent bytes) ---
  # Only GNU du -b gives reliable logical bytes. BSD du -A is inconsistent
  # across versions (macOS ignores it, FreeBSD uses it, OpenBSD uses 512-blocks),
  # so we use stat summation for all non-GNU systems.

  if [ "$has_gnu_du" -eq 1 ]; then
    # GNU: -b gives logical bytes directly
    dir_logical_bytes=$(du -sb "${CACHE_DIR}" 2>/dev/null | awk '{print $1}')
  fi

  # For non-GNU systems (macOS, BSD, etc.), use stat summation
  if [ -z "$dir_logical_bytes" ] || [ "$dir_logical_bytes" = "0" ]; then
    if [ "$has_bsd_stat" -eq 1 ] || [ "$has_gnu_stat" -eq 1 ]; then
      dir_logical_bytes=0
      _tf=$(mktemp -t rt_stat.XXXXXX 2>/dev/null || mktemp)
      find "${CACHE_DIR}" -type f 2>/dev/null > "$_tf" || true
      while IFS= read -r f; do
        [ -z "$f" ] && continue
        local sz=0
        if [ "$has_bsd_stat" -eq 1 ]; then
          sz=$(stat -f %z "$f" 2>/dev/null || echo 0)
        else
          sz=$(stat -c %s "$f" 2>/dev/null || echo 0)
        fi
        case "$sz" in ''|*[!0-9]*) sz=0 ;; esac
        dir_logical_bytes=$((dir_logical_bytes + sz))
      done < "$_tf"
      rm -f "$_tf"
    fi
  fi

  # Final fallback
  if [ -z "$dir_logical_bytes" ] || [ "$dir_logical_bytes" = "0" ]; then
    dir_logical_bytes=$size_bytes
  fi

  # --- Calculate physical size (disk blocks) ---
  if [ "$has_gnu_du" -eq 1 ]; then
    # GNU: --block-size=1 gives bytes
    dir_physical_bytes=$(du -s --block-size=1 "${CACHE_DIR}" 2>/dev/null | awk '{print $1}')
  elif command -v du >/dev/null 2>&1; then
    # BSD/macOS: -sk gives 1024-byte blocks (physical)
    dir_physical_bytes=$(du -sk "${CACHE_DIR}" 2>/dev/null | awk '{print $1}')
    if [ -n "$dir_physical_bytes" ]; then
      dir_physical_bytes=$((dir_physical_bytes * 1024))
    fi
  fi

  # Fallback to stat blocks
  if [ -z "$dir_physical_bytes" ] || [ "$dir_physical_bytes" = "0" ]; then
    if [ "$has_bsd_stat" -eq 1 ] || [ "$has_gnu_stat" -eq 1 ]; then
      dir_physical_bytes=0
      _tf=$(mktemp -t rt_stat.XXXXXX 2>/dev/null || mktemp)
      find "${CACHE_DIR}" -type f 2>/dev/null > "$_tf" || true
      while IFS= read -r f; do
        [ -z "$f" ] && continue
        local blocks=0
        if [ "$has_bsd_stat" -eq 1 ]; then
          blocks=$(stat -f %b "$f" 2>/dev/null || echo 0)
        else
          blocks=$(stat -c %b "$f" 2>/dev/null || echo 0)
        fi
        case "$blocks" in ''|*[!0-9]*) blocks=0 ;; esac
        dir_physical_bytes=$((dir_physical_bytes + blocks * 512))
      done < "$_tf"
      rm -f "$_tf"
    fi
  fi

  # --- Format output ---
  dir_logical_human=$(_human_size "$dir_logical_bytes")

  if [ -n "$dir_physical_bytes" ] && [ "$dir_physical_bytes" != "0" ]; then
    dir_physical_human=$(_human_size "$dir_physical_bytes")
  else
    dir_physical_human="N/A"
    dir_physical_bytes="N/A"
  fi

  age_human=$(_human_age "$age")

  printf 'Index file: %s\nIndex entries: %s\nAge: %s\nIndex file size: %s (%s bytes)\nIndex directory (logical): %s (%s bytes)\nDisk usage: %s (%s bytes)\n' \
    "${CACHE_FILE}" "$count" "$age_human" "$size_human" "$size_bytes" \
    "$dir_logical_human" "$dir_logical_bytes" \
    "$dir_physical_human" "$dir_physical_bytes"

  # --- Language index stats ---
  for f in "${CACHE_DIR}"/mos.index.lang.*; do
    [ -f "$f" ] || continue
    case "$f" in
      *.count)
        c=$(tr -d '[:space:]' <"$f" 2>/dev/null || echo 0)
        case "$c" in ''|*[!0-9]*) c=0 ;; esac
        idx_total=$((idx_total + c))
        ;;
      *) [ -s "$f" ] && idx_files=$((idx_files + 1)) ;;
    esac
  done

  printf 'Language indexes: %s\nIndexed entries: %s\n' "$idx_files" "$idx_total"
}

# Debug trace of chosen index file
_debug "resolved CACHE_DIR=${CACHE_DIR:-}"
_debug "resolved CACHE_FILE=${CACHE_FILE:-}"

# --index-stats should work without LANGS
if [ "${INDEX_STATS:-0}" -eq 1 ]; then
  if _print_cache_stats; then
    exit 0
  else
    echo "No index found at: ${CACHE_FILE:-}" >&2
    echo "The index is auto-built on first use. Run with any language to create it, for example:" >&2
    echo "  random-translation es" >&2
    exit 0
  fi
fi

# `selected` is set either by --file or by the discovery block below.
# Initialize to empty so set -u doesn't trigger if somehow neither path runs.
selected=""

# --file: validate and set selected directly; skip all discovery.
# Extraction happens in the normal dispatch below (after functions are defined).
if [ -n "${MO_FILE:-}" ]; then
  if [ ! -f "$MO_FILE" ]; then
    echo "error: --file path does not exist or is not a file: $MO_FILE" >&2
    exit 1
  fi
  selected="$MO_FILE"
  _debug "--file bypass, selected: $selected"
fi

# If strategy index-only and no LANGS, show index status (instead of falling through to usage).
if [ "${STRATEGY:-}" = "index-only" ] && [ -z "${LANGS:-}" ]; then
  if _print_cache_stats; then
    echo "Note: --strategy index-only implies --index-mode read; showing index status." >&2
    echo >&2
    echo "To sample translations, provide one or more LANGS, e.g.:" >&2
    echo "  random-translation -n 1 el tr es" >&2
    exit 0
  else
    _print_cache_missing "--strategy index-only"
    exit 3
  fi
fi

# Normalize languages: convert commas to spaces, trim
LANGS=$(printf '%s\n' "$LANGS" | awk 'BEGIN{ORS=" "} {gsub(/,/," "); for(i=1;i<=NF;i++) print $i}' | sed 's/^ *//; s/ *$//')

# Only require LANGS when the user actually needs to select translations.
# Allow --index-stats, --strategy index-only, and --file to run without LANGS.
if [ -z "$LANGS" ] && [ "${INDEX_STATS:-0}" -eq 0 ] && [ "${STRATEGY:-}" != "index-only" ] && [ "${INDEX_INIT:-0}" -eq 0 ] && [ -z "${MO_FILE:-}" ]; then
  echo "error: no languages specified." >&2
  echo >&2
  echo "Usage: random-translation LANG [LANG...]" >&2
  echo >&2
  echo "  Single language:   random-translation es" >&2
  echo "  Multiple:          random-translation es fr de" >&2
  echo "  Comma-separated:   random-translation es,fr,de" >&2
  echo "  Locale variant:    random-translation es_ES" >&2
  echo >&2
  echo "Run --help for full usage." >&2
  exit 1
fi

case "$N_STRINGS" in
  ''|*[!0-9]*)
    echo "error: -n requires a positive integer (got: $N_STRINGS)" >&2
    exit 1
    ;;
  0) ;;
  *)
    if [ "$N_STRINGS" -lt 1 ]; then
      echo "error: -n must be a positive integer (got: $N_STRINGS)" >&2
      exit 1
    fi
    ;;
esac

case "$TTL" in
  ''|*[!0-9]*)
    echo "error: --ttl requires a positive integer number of seconds (got: $TTL)" >&2
    exit 1
    ;;
  0)
    echo "error: --ttl must be at least 1 second (got: 0)" >&2
    exit 1
    ;;
esac

case "$MO_READER" in
  auto|msgunfmt|od) ;;
  *)
    echo "error: invalid --reader value: $MO_READER (expected: auto|msgunfmt|od)" >&2
    exit 1
    ;;
esac
# Validate output, theme, and color — always checked regardless of --file
case "$OUTPUT_MODE" in
  human|raw|json|yaml|filename) ;;
  *)
    echo "error: invalid --output value: $OUTPUT_MODE" >&2
    exit 1
    ;;
esac

case "$THEME" in
  aurora|cyberpunk|neon|sakura|classic|tokyonight|ocean|mars|jungle|phosphor) ;;
  *)
    echo "error: invalid --theme value: $THEME" >&2
    echo >&2
    echo "valid themes: aurora, cyberpunk, neon, sakura, classic, tokyonight, ocean, mars, jungle, phosphor" >&2
    exit 1
    ;;
esac

case "$COLOR_MODE" in
  auto|always|never) ;;
  *)
    echo "error: invalid --color value: $COLOR_MODE" >&2
    exit 1
    ;;
esac

#
# Skip all index machinery and discovery when --file is given.
# selected is already set; _selected_index is empty (no index to retry from).
#
_selected_index=""
if [ -z "${MO_FILE:-}" ]; then

if [ "${INDEX_INIT:-0}" -eq 1 ]; then
  if [ "${CACHE_MODE_SET:-0}" -eq 1 ]; then
    echo "error: --index-init cannot be combined with --index-mode" >&2
    exit 1
  fi
  # --strategy may be specified to choose the scan method; default to deep (or quick on WSL)
  if [ "${STRATEGY_SET:-0}" -eq 0 ]; then
    if [ "${IS_WSL:-0}" -eq 1 ]; then
      STRATEGY="quick"
    else
      STRATEGY="deep"
    fi
  fi
  STRATEGY_SET=1
  CACHE_MODE="write"
  CACHE_MODE_SET=1
  REFRESH=1
fi

# Resolve default interface:
#   - no explicit strategy/index-mode => auto mode (deep build first, index-only thereafter)
#   - explicit strategy without index-mode keeps old behavior: index-only -> read, others -> none
#   - explicit index-mode without strategy picks a sensible companion strategy
if [ "${STRATEGY_SET:-0}" -eq 0 ] && [ "${CACHE_MODE_SET:-0}" -eq 1 ]; then
  case "$CACHE_MODE" in
    read)  STRATEGY="index-only" ;;
    write) STRATEGY="deep" ;;
    none)  STRATEGY="quick" ;;
  esac
fi

if [ "${STRATEGY_SET:-0}" -eq 1 ] && [ "${CACHE_MODE_SET:-0}" -eq 0 ]; then
  case "$STRATEGY" in
    index-only) CACHE_MODE="read" ;;
    auto) ;;
    *) CACHE_MODE="none" ;;
  esac
fi

if [ "${STRATEGY:-}" = "auto" ]; then
  if [ "${CACHE_MODE_SET:-0}" -eq 1 ]; then
    echo "error: --strategy auto does not accept an explicit --index-mode" >&2
    echo "Hint: omit --index-mode for automatic behavior, or choose a manual strategy." >&2
    exit 1
  fi
  if [ "${REFRESH:-0}" -eq 1 ] || [ ! -f "${CACHE_FILE:-}" ]; then
    if [ "${IS_WSL:-0}" -eq 1 ]; then
      # On WSL, deep scan crosses slow DrvFs mounts under /mnt.
      # Use the quick strategy for first-run; user can explicitly rebuild with deep.
      STRATEGY="quick"
      _debug "auto mode → quick write (WSL)"
    else
      STRATEGY="deep"
      _debug "auto mode → deep write"
    fi
    CACHE_MODE="write"
  else
    STRATEGY="index-only"
    CACHE_MODE="read"
    _debug "auto mode → index-only read"
  fi
fi

# Validate strategy-specific options
if [ "${STRATEGY:-}" = "targeted" ] && [ -z "${ROOTS:-}" ]; then
  echo "error: --strategy targeted requires --roots." >&2
  echo >&2
  echo "--roots expects a colon-separated list of locale directories to scan, for example:" >&2
  echo "  --roots '/usr/share/locale:/usr/local/share/locale'" >&2
  echo >&2
  echo "Full example:" >&2
  echo "  random-translation --strategy targeted --roots '/usr/share/locale' el" >&2
  exit 1
fi

if [ "${STRATEGY:-}" = "index-only" ]; then
  if [ "${CACHE_MODE:-}" != "read" ]; then
    echo "error: --strategy index-only only supports --index-mode read" >&2
    echo "Hint: use --strategy host-indexed|deep with --index-mode write to rebuild the index." >&2
    exit 1
  fi
  if [ "${REFRESH:-0}" -eq 1 ]; then
    echo "error: --refresh cannot be used with --strategy index-only" >&2
    echo "Hint: rebuild with --strategy host-indexed|deep --index-mode write --refresh LANG." >&2
    exit 1
  fi
fi

# Validate CACHE_MODE and STRATEGY (only relevant for discovery path)
case "$CACHE_MODE" in
  read|write|none) ;;
  *)
    echo "error: invalid --index-mode value: $CACHE_MODE" >&2
    exit 1
    ;;
esac

case "$STRATEGY" in
  auto|quick|host-indexed|targeted|deep|index-only) ;;
  *)
    echo "error: invalid --strategy value: $STRATEGY" >&2
    exit 1
    ;;
esac


append_dir() {
  local new="$1"
  case ":$LOCALE_DIRS:" in *":$new:"*) ;; *) LOCALE_DIRS="${LOCALE_DIRS}:$new" ;; esac
}

# If user provided --roots, add them to LOCALE_DIRS
if [ -n "$ROOTS" ]; then
  _ifs_save="$IFS"; IFS=':'
  # shellcheck disable=SC2086
  set -- $ROOTS
  IFS="$_ifs_save"
  for r in "$@"; do [ -n "$r" ] && append_dir "$r"; done
fi

# Enable filtering only when requested explicitly. By default deep scans are
# unrestricted which avoids accidentally omitting system-wide locations when
# performing a full deep scan. If --filter is provided it overrides the
# locale-dir filter list.
if [ -n "$ROOTS" ] || [ -n "${FILTER_PATTERNS:-}" ]; then
  SKIP_LOCALE_FILTER=0
  if [ -n "${FILTER_PATTERNS:-}" ]; then
    LOCALE_DIRS="$FILTER_PATTERNS"
  fi
fi

_discover_debug() {
  local debug="${1:-0}"
  shift || true
  [ "$debug" -eq 1 ] && printf 'DEBUG: %s\n' "$*" >&2
  return 0
}

_discover_run_append() {
  local cache="$1"
  shift
  "$@" >>"$cache" 2>/dev/null
  case $? in
    0|1) return 0 ;;
    130|143) return 130 ;;
    *) return 0 ;;
  esac
}

_macos_deep_locale_roots() {
  local candidate prefix

  {
    # Explicit LOCALE_DIRS override (honour same convention as Linux)
    _ifs_save="$IFS"; IFS=':'
    # shellcheck disable=SC2086
    set -- ${LOCALE_DIRS:-}
    IFS="$_ifs_save"
    for candidate in "$@"; do
      [ -n "$candidate" ] && [ -d "$candidate" ] && printf '%s\n' "$candidate"
    done

    # Standard / FHS-style paths present on macOS
    for candidate in \
      /usr/share/locale \
      /usr/local/share/locale \
      /usr/local/lib/locale
    do
      _print_if_dir "$candidate"
    done

    # Homebrew (Apple Silicon prefix first, then Intel)
    for prefix in /opt/homebrew /usr/local; do
      _print_if_dir "$prefix/share/locale"
      # Per-formula locale dirs: e.g. /opt/homebrew/opt/gettext/share/locale
      for candidate in "$prefix"/opt/*/share/locale; do
        _print_if_dir "$candidate"
      done
    done

    # MacPorts and Fink
    for candidate in \
      /opt/local/share/locale \
      /opt/sw/share/locale
    do
      _print_if_dir "$candidate"
    done

    # Nix (single-user and multi-user)
    for candidate in \
      /nix/store/*/share/locale \
      "$HOME"/.nix-profile/share/locale
    do
      _print_if_dir "$candidate"
    done

  } | awk '!seen[$0]++'
  return 0
}

_discover_deep_darwin() {
  local cache="$1" debug="$2" locale_roots locale_root

  locale_roots="$(_macos_deep_locale_roots)"
  while IFS= read -r locale_root; do
    [ -n "$locale_root" ] || continue
    [ -d "$locale_root" ] || continue
    _discover_debug "$debug" "deep scan locale root: $locale_root"
    _discover_run_append "$cache" find "$locale_root" -xdev -type f -path '*/LC_MESSAGES/*.mo' -print || return $?
  done <<EOF
$locale_roots
EOF
}

_linux_deep_roots() {
  {
    printf '/\n'
    if [ -r /proc/self/mountinfo ]; then
      awk '
        {
          sep = 0
          for (i = 1; i <= NF; i++) {
            if ($i == "-") {
              sep = i
              break
            }
          }
          if (sep == 0 || sep + 1 > NF) next

          mount_point = $5
          fs_type = $(sep + 1)

          gsub(/\\040/, " ", mount_point)
          gsub(/\\011/, "\t", mount_point)
          gsub(/\\012/, "\n", mount_point)
          gsub(/\\134/, "\\", mount_point)

          if (mount_point == "/") next
          if (mount_point ~ /^\/(proc|sys|dev|run)(\/|$)/) next
          if (mount_point ~ /^\/mnt(\/|$)/) next
          if (fs_type ~ /^(proc|sysfs|devtmpfs|devpts|tmpfs|cgroup|cgroup2|pstore|bpf|securityfs|tracefs|configfs|debugfs|fusectl|mqueue|hugetlbfs|rpc_pipefs|autofs|binfmt_misc|nsfs|overlay|squashfs)$/) next
          if (fs_type ~ /^(fuse|fuse\..*|nfs|nfs4|cifs|smbfs|9p|drvfs)$/) next

          print mount_point
        }
      ' /proc/self/mountinfo 2>/dev/null || true
    fi
  } | awk '!seen[$0]++'
}

_print_if_dir() {
  local d="$1"
  case "$d" in
    //*) d="/${d#//}" ;;
  esac
  if [ -n "$d" ] && [ -d "$d" ]; then
    printf '%s\n' "$d"
  fi
  return 0
}

_linux_deep_locale_roots() {
  local mount_roots mount_root locale_root candidate

  {
    _ifs_save="$IFS"; IFS=':'
    # shellcheck disable=SC2086
    set -- ${LOCALE_DIRS:-}
    IFS="$_ifs_save"
    for locale_root in "$@"; do
      [ -n "$locale_root" ] && [ -d "$locale_root" ] && printf '%s\n' "$locale_root"
    done

    mount_roots="$(_linux_deep_roots)"
    while IFS= read -r mount_root; do
      [ -n "$mount_root" ] || continue
      [ -d "$mount_root" ] || continue

      case "$mount_root" in
        /) ;;
        *) _print_if_dir "$mount_root/share/locale" ;;
      esac

      for candidate in \
        "$mount_root/usr/share/locale" \
        "$mount_root/usr/local/share/locale" \
        "$mount_root/usr/share/locale-langpack" \
        "$mount_root/usr/lib/locale" \
        "$mount_root/usr/local/lib/locale" \
        "$mount_root/lib/locale" \
        "$mount_root/var/lib/flatpak/exports/share/locale" \
        "$mount_root/var/lib/snapd/desktop/locale"
      do
        _print_if_dir "$candidate"
      done

      for candidate in \
        "$mount_root"/opt/*/share/locale \
        "$mount_root"/opt/*/*/share/locale \
        "$mount_root"/var/lib/flatpak/app/*/*/*/*/files/share/locale \
        "$mount_root"/nix/store/*/share/locale
      do
        _print_if_dir "$candidate"
      done
    done <<EOF
$mount_roots
EOF
  } | awk '!seen[$0]++'
  return 0
}

_discover_deep_linux() {
  local cache="$1" debug="$2" locale_roots locale_root

  locale_roots="$(_linux_deep_locale_roots)"
  while IFS= read -r locale_root; do
    [ -n "$locale_root" ] || continue
    [ -d "$locale_root" ] || continue
    _discover_debug "$debug" "deep scan locale root: $locale_root"
    _discover_run_append "$cache" find "$locale_root" -xdev -type f -path '*/LC_MESSAGES/*.mo' -print || return $?
  done <<EOF
$locale_roots
EOF
}

# Discovery dispatcher with debug messages
discover_mo_list() {
  local strategy="$1"; local cache="$2"; local debug="$3"; local roots="$4"
  : >"$cache"

  case "$strategy" in
    quick)
      [ "$debug" -eq 1 ] && echo "DEBUG: quick strategy scanning common roots" >&2
      for d in /usr/share/locale /usr/local/share/locale /opt/homebrew/share/locale $roots; do
        [ -z "$d" ] && continue
        [ -d "$d" ] || continue
        [ "$debug" -eq 1 ] && echo "DEBUG: find under $d (shallow)" >&2
        _discover_run_append "$cache" find "$d" -type f -path '*/LC_MESSAGES/*.mo' -maxdepth 6 -print || return $?
      done
      ;;

    host-indexed)
      [ "$debug" -eq 1 ] && echo "DEBUG: host-indexed strategy using mdfind/locate if available" >&2
      if command -v mdfind >/dev/null 2>&1; then
        [ "$debug" -eq 1 ] && echo "DEBUG: using mdfind" >&2
        mdfind "kMDItemFSName == '*.mo'c" 2>/dev/null | grep -i '\.mo$' >>"$cache" || true
      elif command -v locate >/dev/null 2>&1; then
        [ "$debug" -eq 1 ] && echo "DEBUG: using locate" >&2
        locate '*.mo' 2>/dev/null | grep -i '\.mo$' >>"$cache" || true
      else
        [ "$debug" -eq 1 ] && echo "DEBUG: no host indexer found; falling back to limited find" >&2
        for d in /usr/share /usr/local /opt /Applications; do
          [ -d "$d" ] || continue
          _discover_run_append "$cache" find "$d" -type f -iname '*.mo' -maxdepth 6 -print || return $?
        done
      fi
      ;;

    targeted)
      [ "$debug" -eq 1 ] && echo "DEBUG: targeted strategy scanning roots: $roots" >&2
      _ifs_save="$IFS"; IFS=':'
      # shellcheck disable=SC2086
      set -- $roots
      IFS="$_ifs_save"
      for d in "$@"; do
        [ -z "$d" ] && continue
        [ -d "$d" ] || continue
        [ "$debug" -eq 1 ] && echo "DEBUG: find under $d (targeted)" >&2
        _discover_run_append "$cache" find "$d" -type f -path '*/LC_MESSAGES/*.mo' -maxdepth 6 -print || return $?
      done
      ;;

    deep)
      [ "$debug" -eq 1 ] && echo "DEBUG: deep strategy full scan" >&2
      case "${OS:-}" in
        Linux)
          _discover_debug "$debug" "deep strategy using mount-aware linux scan"
          _discover_deep_linux "$cache" "$debug"
          ;;
        Darwin)
          _discover_debug "$debug" "deep strategy using macOS scan"
          _discover_deep_darwin "$cache" "$debug"
          ;;
        *)
          # Generic fallback: scan known paths; avoid virtual/slow filesystems
          _discover_debug "$debug" "deep strategy using generic fallback scan"
          for d in /usr/share /usr/local /opt; do
            [ -d "$d" ] || continue
            _discover_run_append "$cache" find "$d" -type f -iname '*.mo' -maxdepth 8 -print || return $?
          done
          ;;
      esac
      ;;

    index-only)
      [ "$debug" -eq 1 ] && echo "DEBUG: index-only strategy: reading existing index, no discovery" >&2
      # do nothing
      ;;

    *)
      echo "error: unknown strategy: $strategy" >&2
      return 1
      ;;
  esac

  if [ -s "$cache" ]; then
    awk '!seen[$0]++' "$cache" >"${cache}.uniq" || true
    mv "${cache}.uniq" "$cache"
  fi
  return 0
}

# Compact, correct index-mode logic
rebuild_cache=0
# Default: do not filter results by LOCALE_DIRS unless the user explicitly
# requests filtering via --roots or --filter. When SKIP_LOCALE_FILTER=1 the
# locale-dir prefix filter is disabled and deep scans are unrestricted.
SKIP_LOCALE_FILTER=1

case "$CACHE_MODE" in
  none)
    # Completely ignore index: no read, no write, no TTL, no fallback
    _debug "index-mode=none → ignoring index entirely"
    rebuild_cache=1
    SKIP_LOCALE_FILTER=1
    ;;

  read)
    # Read-only: rebuild only if --refresh
    if [ "$REFRESH" -eq 1 ]; then
      rebuild_cache=1
    else
      if [ ! -f "${CACHE_FILE:-}" ]; then
        _print_cache_missing "--index-mode read"
        exit 3
      fi
      _debug "index-mode=read → using existing index"
    fi
    ;;

  write)
    # Write mode: rebuild if refresh, missing, or TTL expired
    if [ "$REFRESH" -eq 1 ] || [ ! -f "${CACHE_FILE:-}" ]; then
      rebuild_cache=1
    else
      now=$(date +%s)
      if stat -f %m "${CACHE_FILE}" >/dev/null 2>&1; then
        mtime=$(stat -f %m "${CACHE_FILE}")
      else
        mtime=$(stat -c %Y "${CACHE_FILE}" 2>/dev/null || echo 0)
      fi
      age=$((now - mtime))
      [ "$age" -ge "$TTL" ] && rebuild_cache=1

      _debug "index-mode=write → age=$age TTL=$TTL rebuild=$rebuild_cache"
    fi
    ;;
esac

#
# Language index: build and use per-language index files for fast lookup.
#
# An index file (e.g. mos.index.lang.el) is a pre-filtered list of .mo paths for
# one language code, written alongside the master index on every index-mode=write
# run. Lookup can then pick from per-language indexes without scanning the full
# master index.
#

# Normalise language codes: replace hyphens with underscores
_norm_lang() { printf '%s' "$1" | sed 's/-/_/g'; }
_lang_index_file() { printf '%s/mos.index.lang.%s' "$1" "$2"; }

#
# Build per-language index files from the master index (called after index write).
# One awk pass groups every path by its locale-directory component, then writes
# one index file per discovered language code.
#
_build_lang_indexes() {
  local cache_file="$1" cache_dir="$2" locale_dirs="$3" skip_filter="$4"
  _debug "building per-language index files"
  # Remove stale per-language index artifacts before rebuilding.
  local f
  for f in "$cache_dir"/mos.index.lang.*; do
    [ -e "$f" ] || continue
    rm -f -- "$f"
  done

  awk -v locale_dirs="$locale_dirs" -v skip_filter="$skip_filter" -v outdir="$cache_dir" '
    BEGIN { nd = split(locale_dirs, roots, ":") }
    {
      f = $0
      if (!skip_filter) {
        ok = 0
        for (i=1; i<=nd; i++) {
          if (roots[i] != "" && index(f, roots[i] "/") == 1) { ok=1; break }
        }
        if (!ok) next
      }
      if (match(f, /\/LC_MESSAGES\//)) {
        left = substr(f, 1, RSTART-1)
        n = split(left, parts, "/"); lang = parts[n]
      } else {
        n = split(f, parts, "/"); lang = parts[n-1]
      }
      gsub(/-/, "_", lang)
      sub(/[.@].*/, "", lang)
      gsub(/[^[:alnum:]_]/, "", lang)
      if (lang == "") next
      idx = outdir "/mos.index.lang." lang
      key = idx SUBSEP f
      if (!seen[key]++) {
        print f >> idx
        count[idx]++
      }
    }
    END {
      for (idx in count) {
        cfile = idx ".count"
        print count[idx] > cfile
        close(cfile)
        close(idx)
      }
    }
  ' "$cache_file"

  if [ "$DEBUG" -eq 1 ]; then
    for f in "$cache_dir"/mos.index.lang.*; do
      [ -f "$f" ] || continue
      case "$f" in
        *.count) continue ;;
      esac
      _debug "index $(wc -l <"$f" | tr -d ' ') entries → $f"
    done
  fi
}

# Build or load index according to rebuild decision
if [ "$rebuild_cache" -eq 1 ]; then
  TMP_CACHE="$(mktemp -t mos.index.XXXXXX 2>/dev/null || mktemp)"
  _CLEANUP_TMP_CACHE="$TMP_CACHE"
  trap 'rm -f "${_CLEANUP_TMP_CACHE:-}" "${_CLEANUP_TMP_MATCH:-}"' EXIT

  discover_mo_list "$STRATEGY" "$TMP_CACHE" "$DEBUG" "$ROOTS"

  if [ "$CACHE_MODE" = "write" ]; then
    mkdir -p "$(dirname "${CACHE_FILE}")" 2>/dev/null || true
    mv "$TMP_CACHE" "$CACHE_FILE"
    _debug "index written with $(wc -l <"${CACHE_FILE}" | tr -d ' ') entries"
    _build_lang_indexes "$CACHE_FILE" "$(dirname "$CACHE_FILE")" "$LOCALE_DIRS" "$SKIP_LOCALE_FILTER"
  else
    # Transient list for this run
    CACHE_FILE="$TMP_CACHE"
    _debug "transient list built with $(wc -l <"$CACHE_FILE" | tr -d ' ') entries (not persisted)"
  fi

else
  # Only reached for index-mode read/write when rebuild not required
  _debug "using existing index file: ${CACHE_FILE:-} (mode=$CACHE_MODE)"
fi

# Ensure index file exists and has entries
if [ ! -s "${CACHE_FILE:-}" ]; then
  # Only call it "index empty" when we actually consulted a persistent index (index-mode read/write and not transient).
  if [ "$CACHE_MODE" = "read" ] || [ "$CACHE_MODE" = "write" ]; then
    echo >&2
    echo "No .mo files found (index empty)." >&2
    echo >&2
    echo "Hint: you asked to use the index; the index exists but contains no entries." >&2
    echo >&2
    echo "To build an index of installed .mo files, run:" >&2
    echo "  ./random-translation --strategy indexed --index-mode write --refresh LANG" >&2
    echo "or, for a full scan (slower):" >&2
    echo "  ./random-translation --strategy deep --index-mode write --refresh LANG" >&2
    echo >&2
    echo "Why: the index is authoritative for fast runs, but index rebuild strategy still matters when" >&2
    echo "discovering translation files. Using 'indexed' (mdfind/locate) or" >&2
    echo "'deep' (full scan) and writing the results to the index ensures subsequent runs are fast." >&2
  else
    # index-mode none (transient discovery) — explain explicit no-index discovery and suggest building an index
    echo >&2
    echo "No .mo files found." >&2
    echo >&2
    echo "Note: explicit no-index mode defaults to the 'quick' discovery strategy, which may not find" >&2
    echo "installed .mo files on some systems. To build a persistent index that covers more locations," >&2
    echo "run one of the following (replace LANG with your language codes):" >&2
    echo "  ./random-translation --strategy indexed --index-mode write --refresh LANG" >&2
    echo "  ./random-translation --strategy deep --index-mode write --refresh LANG" >&2
    echo >&2
    echo "After building the index you can run without --refresh for faster selection." >&2
  fi
  exit 3
fi

if [ "${INDEX_INIT:-0}" -eq 1 ]; then
  _print_cache_stats
  exit 0
fi

# Normalise requested languages
NORMALS=""
for l in $LANGS; do
  NORMALS="${NORMALS} $(_norm_lang "$l")"
done
NORMALS="${NORMALS# }"

TMP_MATCH="$(mktemp -t mos.match.XXXXXX 2>/dev/null || mktemp)"
_CLEANUP_TMP_MATCH="$TMP_MATCH"
trap 'rm -f "${_CLEANUP_TMP_CACHE:-}" "${_CLEANUP_TMP_MATCH:-}"' EXIT

#
# Fast path: when per-language indexes exist, pick a file using weighted counts
# and choose a random entry from that file. This avoids full-index scans.
#
_use_fast_path=0
if [ "$CACHE_MODE" != "none" ]; then
  _all_indexed=1
  _total_count=0
  _weighted=""
  for lang in $NORMALS; do
    _base="${lang%%_*}"
    idx="$(_lang_index_file "$CACHE_DIR" "$lang")"
    idx_base="$(_lang_index_file "$CACHE_DIR" "$_base")"
    if [ -s "$idx" ]; then
      cfile="${idx}.count"
      c=0
      [ -s "$cfile" ] && c=$(tr -d '[:space:]' <"$cfile" 2>/dev/null || echo 0)
      case "$c" in
        ''|*[!0-9]*) c=0 ;;
      esac
      [ "$c" -eq 0 ] && c=$(wc -l <"$idx" | tr -d ' ')
      _weighted="${_weighted}${idx}"$'\t'"${c}"$'\n'
      _total_count=$((_total_count + c))
    elif [ "$lang" != "$_base" ] && [ -s "$idx_base" ]; then
      cfile="${idx_base}.count"
      c=0
      [ -s "$cfile" ] && c=$(tr -d '[:space:]' <"$cfile" 2>/dev/null || echo 0)
      case "$c" in
        ''|*[!0-9]*) c=0 ;;
      esac
      [ "$c" -eq 0 ] && c=$(wc -l <"$idx_base" | tr -d ' ')
      _weighted="${_weighted}${idx_base}"$'\t'"${c}"$'\n'
      _total_count=$((_total_count + c))
    else
      _all_indexed=0; break
    fi
  done
  if [ "$_all_indexed" -eq 1 ] && [ "$_total_count" -gt 0 ]; then
    pick=$(
      awk -v total="$_total_count" '
        BEGIN {
          srand()
          r = int(rand() * total) + 1
          acc = 0
        }
        NF >= 2 {
          path = $1
          c = $2 + 0
          if (c <= 0) next
          acc += c
          if (acc >= r) { print path; exit }
        }
      ' <<EOF_WEIGHTED
$_weighted
EOF_WEIGHTED
    )
    if [ -n "$pick" ] && [ -s "$pick" ]; then
      lines=$(wc -l <"$pick" | tr -d ' ')
      if [ "$lines" -gt 0 ]; then
        line_pick=$(awk -v total="$lines" 'BEGIN { srand(); print int(rand() * total) + 1 }')
        selected=$(awk -v want="$line_pick" 'NR==want{print; exit}' "$pick")
        _selected_index="$pick"
      fi
    fi
  fi
  if [ -n "${selected:-}" ]; then
    _use_fast_path=1
    _debug "fast path via language index files (weighted random)"
  else
    _debug "index unavailable/incomplete, falling back to awk scan"
  fi
fi

#
# Standard path: single awk pass over the master index.
# Used for all strategies other than index-only, or when per-language indexes are absent.
#
if [ "$_use_fast_path" -eq 0 ]; then
  awk -v langs="$NORMALS" -v locale_dirs="$LOCALE_DIRS" -v skip_filter="$SKIP_LOCALE_FILTER" '
    BEGIN {
      nd = split(locale_dirs, roots, ":")
      nl = split(langs, wanted, " ")
    }
    {
      f = $0
      if (!skip_filter) {
        ok = 0
        for (i=1; i<=nd; i++) {
          if (roots[i] != "" && index(f, roots[i] "/") == 1) { ok=1; break }
        }
        if (!ok) next
      }
      if (match(f, /\/LC_MESSAGES\//)) {
        left = substr(f, 1, RSTART-1)
        n = split(left, parts, "/"); lcnorm = parts[n]
      } else {
        n = split(f, parts, "/"); lcnorm = parts[n-1]
      }
      gsub(/-/, "_", lcnorm)
      for (i=1; i<=nl; i++) {
        w = wanted[i]
        if (lcnorm == w \
            || index(lcnorm, w "_") == 1 \
            || index(lcnorm, w ".") == 1 \
            || index(lcnorm, w "-") == 1 \
            || (index(lcnorm, w) == 1 && length(lcnorm) > length(w))) {
          if (!seen[f]++) print f
          break
        }
      }
    }
  ' "${CACHE_FILE}" > "$TMP_MATCH"
fi

if [ "$_use_fast_path" -eq 0 ] && [ ! -s "$TMP_MATCH" ]; then
  [ "$DEBUG" -eq 1 ] && { echo "DEBUG: index sample (first 50):" >&2; head -n 50 "${CACHE_FILE}" >&2 || true; }
  echo "No .mo files found for languages: $LANGS" >&2
  exit 3
fi

if [ "$_use_fast_path" -eq 0 ]; then
  count=$(wc -l <"$TMP_MATCH" | tr -d ' ')
  _debug "matched $count .mo files for languages: $LANGS"
  selected=$(awk 'BEGIN{srand()} {a[NR]=$0} END{if(NR>0) print a[int(rand()*NR)+1]}' "$TMP_MATCH" || true)
fi
if [ -z "$selected" ]; then
  _debug "no selection possible"
  echo "No .mo file would be selected for languages: $LANGS" >&2
  exit 3
fi
_debug "Selected: $selected"

fi  # end of --file bypass guard (skip index/discovery when --file is set)

# If output mode is filename (or dry-run), print the filename and exit
if [ "$OUTPUT_MODE" = "filename" ]; then
  # Print to stdout for pipeline consumption
  printf '%s\n' "$selected"
  exit 0
fi

#
# Extraction layer
#
# All output modes flow through a single pipeline:
#
#   _mo_read FILE  →  "msgid_json"\t"msgstr_json"\n  (one pair per line)
#       │
#       ├── _fmt_human    (human-readable, themed, no jargon — default)
#       ├── _fmt_raw      (PO-like text, msgunfmt-style, with optional color)
#       ├── _fmt_json     (JSON array, built-in colorizer matching jq -C)
#       └── _fmt_yaml     (YAML list, with optional color)
#
# Why consider `msgunfmt` optional:
#   .mo files are *runtime* artifacts shipped with any application that uses
#   gettext — they are independent of the gettext *developer tools*. A system
#   with hundreds of .mo files under /usr/share/locale may have no msgunfmt
#   at all (Arch minimal, Debian-slim containers, macOS without Homebrew
#   gettext, Alpine, embedded targets, etc.). The od/awk path is therefore the
#   primary path for end-users, not a rare edge case.
#
# Tool requirements:
#   Required : bash(1) ≥3.2, od(1), awk(1), find(1), wc(1), tr(1), mktemp(1)
#   Optional : msgunfmt(1)   — gettext package; used when available for speed
#              jq(1)         — never required; built-in colorizer covers it
#

HAS_MSGUNFMT=0
command -v msgunfmt >/dev/null 2>&1 && HAS_MSGUNFMT=1
_debug "HAS_MSGUNFMT=$HAS_MSGUNFMT MO_READER=$MO_READER"

# Resolve effective reader: honour --reader flag, but don't use msgunfmt when absent
_effective_reader() {
  case "$MO_READER" in
    msgunfmt)
      if [ "$HAS_MSGUNFMT" -eq 0 ]; then
        echo "error: --reader msgunfmt requested but msgunfmt is not installed" >&2
        exit 2
      fi
      echo msgunfmt ;;
    od)
      echo od ;;
    auto)
      if [ "$HAS_MSGUNFMT" -eq 1 ]; then echo msgunfmt; else echo od; fi ;;
  esac
}
_READER="$(_effective_reader)"
_debug "effective reader: $_READER"

#
# _od_convert_charset_pairs CHARSET
#
# Read tab-separated "json"\t"json" pairs from stdin where non-ASCII bytes
# were escaped as \u00XX.  Decode those escapes back to raw bytes, run iconv
# to convert the entire batch from CHARSET to UTF-8 in one pass, then re-
# encode the resulting UTF-8 bytes as JSON pairs on stdout.
#
# Uses ASCII GS (0x1D) and RS (0x1E) as intra-batch delimiters; they survive
# iconv conversion unchanged for all common charsets because they are in the
# shared ASCII range (< 0x80).
#
_od_convert_charset_pairs() {
  local charset="$1" inc_meta="${2:-0}"
  local _batch _converted
  _batch=$(mktemp -t rt_od_batch.XXXXXX 2>/dev/null || mktemp)
  _converted=$(mktemp -t rt_od_conv.XXXXXX 2>/dev/null || mktemp)

  # Pass 1: decode \u00XX JSON escapes → raw bytes; assemble GS-delimited batch
  LC_ALL=C awk '
    BEGIN {
      for (_i=0; _i<256; _i++) _ord[sprintf("%c",_i)] = _i
      _GS = sprintf("%c", 29)   # ASCII GS 0x1D  — field delimiter within pair
      _RS = sprintf("%c", 30)   # ASCII RS 0x1E  — pair delimiter
    }
    function hex2dec(h,    v,i,c) {
      v = 0
      for (i=1; i<=length(h); i++) {
        c = substr(h,i,1)
        if      (c>="0" && c<="9") v = v*16 + (c+0)
        else if (c>="a" && c<="f") v = v*16 + 10 + index("abcdef",c) - 1
        else if (c>="A" && c<="F") v = v*16 + 10 + index("ABCDEF",c) - 1
      }
      return v
    }
    function decode_json(s,    o,i,c) {
      o = ""; i = 1
      while (i <= length(s)) {
        c = substr(s,i,1)
        if (c=="\\" && substr(s,i+1,1)=="u" && substr(s,i+2,2)=="00") {
          o = o sprintf("%c", hex2dec(substr(s,i+4,2))); i += 6
        } else if (c=="\\" && substr(s,i+1,1)=="n") { o = o "\n"; i += 2 }
        else if (c=="\\" && substr(s,i+1,1)=="t") { o = o "\t"; i += 2 }
        else if (c=="\\" && substr(s,i+1,1)=="\\") { o = o "\\"; i += 2 }
        else if (c=="\\" && substr(s,i+1,1)=="\"") { o = o "\""; i += 2 }
        else if (c=="\\" && substr(s,i+1,1)=="r") { o = o "\r"; i += 2 }
        else { o = o c; i++ }
      }
      return o
    }
    {
      tab = index($0, "\t")
      if (tab == 0) next
      mid_json = substr($0, 2, tab-3)                      # strip surrounding quotes
      mst_json = substr($0, tab+2, length($0)-tab-2)
      printf "%s%s%s%s", decode_json(mid_json), _GS, decode_json(mst_json), _RS
    }
  ' > "$_batch"

  # Pass 2: single iconv call converts the whole batch
  iconv -f "$charset" -t UTF-8 < "$_batch" > "$_converted" 2>/dev/null \
    || cp "$_batch" "$_converted"

  # Pass 3: split batch back on RS, re-encode each string as JSON
  LC_ALL=C awk -v inc_meta="$inc_meta" '
    BEGIN {
      for (_i=0; _i<256; _i++) _ord[sprintf("%c",_i)] = _i
      _GS = sprintf("%c", 29)
      RS  = sprintf("%c", 30)
      ORS = ""
    }
    function jstr(s,    o,i,c,v,v2,v3,v4) {
      o = ""; i = 1
      while (i <= length(s)) {
        c = substr(s,i,1); v = _ord[c]
        if      (c=="\\")  { o = o "\\\\"; i++ }
        else if (c=="\"")  { o = o "\\\""; i++ }
        else if (c=="\n")  { o = o "\\n";  i++ }
        else if (c=="\r")  { o = o "\\r";  i++ }
        else if (c=="\t")  { o = o "\\t";  i++ }
        else if (v <  32)  { o = o sprintf("\\u%04x",v); i++ }
        else if (v < 128)  { o = o c; i++ }
        else if (v>=240 && v<=247 && i+3<=length(s)) {
          v2=_ord[substr(s,i+1,1)]; v3=_ord[substr(s,i+2,1)]; v4=_ord[substr(s,i+3,1)]
          if (v2>=128&&v2<=191&&v3>=128&&v3<=191&&v4>=128&&v4<=191) { o=o substr(s,i,4); i+=4 }
          else { o=o sprintf("\\u%04x",v); i++ }
        } else if (v>=224 && v<=239 && i+2<=length(s)) {
          v2=_ord[substr(s,i+1,1)]; v3=_ord[substr(s,i+2,1)]
          if (v2>=128&&v2<=191&&v3>=128&&v3<=191) { o=o substr(s,i,3); i+=3 }
          else { o=o sprintf("\\u%04x",v); i++ }
        } else if (v>=194 && v<=223 && i+1<=length(s)) {
          v2=_ord[substr(s,i+1,1)]
          if (v2>=128&&v2<=191) { o=o substr(s,i,2); i+=2 }
          else { o=o sprintf("\\u%04x",v); i++ }
        } else { o=o sprintf("\\u%04x",v); i++ }
      }
      return o
    }
    {
      gs = index($0, _GS)
      if (gs == 0) next                   # empty trailing record after last RS
      mid = substr($0, 1, gs-1)
      mst = substr($0, gs+1)
      if ((mid == "" && !inc_meta) || mst == "") next
      print "\"" jstr(mid) "\"\t\"" jstr(mst) "\"\n"
    }
  ' "$_converted"

  rm -f "$_batch" "$_converted"
}

#
# _mo_read FILE
#
# Emit every non-header, non-empty msgid/msgstr pair from FILE as:
#   "json-encoded-msgid"\t"json-encoded-msgstr"\n
#
# The values are JSON string content (no surrounding quotes stripped —
# the surrounding quotes ARE included so downstream awk can use them
# directly in JSON output without re-quoting).
#
# Plural-form entries use only the first form (before the first NUL byte).
# The PO header entry (empty msgid) is always skipped.
# msgctxt is encoded into msgid as <ctxt>\x04<id> following gettext convention.
#
_mo_read() {
  local mo="$1"

  if [ "$_READER" = "msgunfmt" ]; then
    #
    # msgunfmt path
    #
    # msgunfmt converts a binary .mo to PO text. We parse it in awk using
    # paragraph mode (RS=""), extracting and JSON-encoding each pair so the
    # output format is identical to the od/awk path.
    #
    # If msgunfmt produces no output (e.g. old gettext on Big Sur, or a file
    # it cannot handle), we fall back to the od/awk path automatically unless
    # --reader msgunfmt was explicitly requested.
    #
    local _msgunfmt_raw _msgunfmt_out _msgunfmt_conv _mo_charset _po_input
    _msgunfmt_out=$(mktemp -t rt_msfmt.XXXXXX 2>/dev/null || mktemp)
    _msgunfmt_raw=$(mktemp -t rt_msfmt_raw.XXXXXX 2>/dev/null || mktemp)
    _msgunfmt_conv=""
    _po_input=""
    # Save msgunfmt output to a file so we can detect charset before parsing.
    # Ignore msgunfmt's exit status — some versions (e.g. macOS/MacGPG2) exit
    # non-zero even when they produce valid PO output; what matters is whether
    # the output file is non-empty.
    msgunfmt "$mo" > "$_msgunfmt_raw" 2>/dev/null || true
    if [ -s "$_msgunfmt_raw" ]; then
      # Detect Content-Type charset from the PO header
      _mo_charset=$(LC_ALL=C grep 'charset=' "$_msgunfmt_raw" 2>/dev/null \
        | head -1 \
        | sed 's/.*charset=//' \
        | sed 's/[^A-Za-z0-9._-].*//')
      _po_input="$_msgunfmt_raw"
      case "$(printf '%s' "${_mo_charset:-UTF-8}" | tr '[:upper:]' '[:lower:]' | tr -d '-')" in
        utf8|ascii|usascii|utf7|"") ;;
        *)
          if command -v iconv >/dev/null 2>&1; then
            _debug "msgunfmt charset=$_mo_charset, converting to UTF-8"
            _msgunfmt_conv=$(mktemp -t rt_msfmt_conv.XXXXXX 2>/dev/null || mktemp)
            iconv -f "$_mo_charset" -t UTF-8 < "$_msgunfmt_raw" > "$_msgunfmt_conv" 2>/dev/null \
              && _po_input="$_msgunfmt_conv" || true
          else
            _debug "msgunfmt charset=$_mo_charset; iconv not available"
          fi ;;
      esac
    fi
    [ -n "$_po_input" ] && LC_ALL=C awk -v inc_meta="$INCLUDE_META" '
      # Line-by-line PO parser — no paragraph mode (RS="") so behavior is
      # identical on BSD awk (macOS), GNU awk, and mawk.  We maintain a small
      # state machine: _in tracks which field we are accumulating ("id", "str",
      # "ctx", "idp", or "" to ignore), _pfuzzy holds a pending fuzzy flag from
      # the most recent #, flags comment before an entry starts.

      BEGIN {
        ORS = ""
        # ord lookup table for JSON encoding
        for (_i = 0; _i < 256; _i++) _ord[sprintf("%c", _i)] = _i
        _cur_id = ""; _cur_str = ""; _in = ""; _fuzzy = 0; _pfuzzy = 0
      }

      # All function definitions come before the rules so that BSD awk, which
      # does not support forward function references, resolves every call site.

      # Expand PO C-escape sequences
      function _po_unescape(s,    o, i, c, n) {
        o = ""; i = 1
        while (i <= length(s)) {
          c = substr(s, i, 1)
          if (c == "\\") {
            n = substr(s, i+1, 1)
            if      (n == "n")  { o = o "\n"; i += 2 }
            else if (n == "t")  { o = o "\t"; i += 2 }
            else if (n == "\\") { o = o "\\"; i += 2 }
            else if (n == "\"") { o = o "\""; i += 2 }
            else if (n == "r")  { o = o "\r"; i += 2 }
            else                { o = o n;    i += 2 }
          } else { o = o c; i++ }
        }
        return o
      }

      # JSON-encode a string value (result has no surrounding quotes).
      # Same UTF-8-aware logic as the od/awk jstr(): valid multi-byte sequences
      # are passed through; lone high bytes are escaped as \u00XX.
      function _jstr(s,    o, i, c, v, v2, v3, v4) {
        o = ""; i = 1
        while (i <= length(s)) {
          c = substr(s, i, 1); v = _ord[c]
          if      (c == "\\") { o = o "\\\\"; i++ }
          else if (c == "\"")  { o = o "\\\"";  i++ }
          else if (c == "\n")  { o = o "\\n";    i++ }
          else if (c == "\r")  { o = o "\\r";    i++ }
          else if (c == "\t")  { o = o "\\t";    i++ }
          else if (v < 32)      { o = o sprintf("\\u%04x", v); i++ }
          else if (v < 128)     { o = o c; i++ }
          else if (v >= 240 && v <= 247 && i+3 <= length(s)) {
            v2=_ord[substr(s,i+1,1)]; v3=_ord[substr(s,i+2,1)]; v4=_ord[substr(s,i+3,1)]
            if (v2>=128&&v2<=191&&v3>=128&&v3<=191&&v4>=128&&v4<=191) { o=o substr(s,i,4); i+=4 }
            else { o = o sprintf("\\u%04x", v); i++ }
          } else if (v >= 224 && v <= 239 && i+2 <= length(s)) {
            v2=_ord[substr(s,i+1,1)]; v3=_ord[substr(s,i+2,1)]
            if (v2>=128&&v2<=191&&v3>=128&&v3<=191) { o=o substr(s,i,3); i+=3 }
            else { o = o sprintf("\\u%04x", v); i++ }
          } else if (v >= 194 && v <= 223 && i+1 <= length(s)) {
            v2=_ord[substr(s,i+1,1)]
            if (v2>=128&&v2<=191) { o=o substr(s,i,2); i+=2 }
            else { o = o sprintf("\\u%04x", v); i++ }
          } else { o = o sprintf("\\u%04x", v); i++ }
        }
        return o
      }

      # Emit the accumulated entry (if valid) then reset all per-entry state.
      function _flush() {
        if ((inc_meta || _cur_id != "") && _cur_str != "" && !_fuzzy) {
          print "\"" _jstr(_cur_id) "\"\t\"" _jstr(_cur_str) "\"\n"
        }
        _cur_id = ""; _cur_str = ""; _in = ""; _fuzzy = 0
      }

      # Normalize CRLF: strip trailing \r so patterns match on Windows-encoded
      # PO files and msgunfmt versions that emit \r\n.
      { sub(/\r$/, "") }

      # Blank line — entry boundary (also resets any pending fuzzy from a
      # comment block that was not followed by an entry).
      /^[[:space:]]*$/ { _flush(); _pfuzzy = 0; next }

      # Comment lines
      /^#,/ { if ($0 ~ /fuzzy/) _pfuzzy = 1; next }
      /^#/  { next }

      # msgctxt — we enter "ctx" state so continuation lines are silently
      # consumed; the context itself is not used (header entries are skipped
      # because their msgid is empty).
      /^msgctxt[[:space:]]/ { _in = "ctx"; next }

      # msgid — flush the previous entry, then start accumulating a new one.
      # _pfuzzy carries the fuzzy flag set by any preceding #, comment.
      /^msgid[[:space:]]/ {
        _flush()
        _fuzzy = _pfuzzy; _pfuzzy = 0
        raw = substr($0, 7)
        if (substr(raw, 1, 1) == "\"") raw = substr(raw, 2, length(raw) - 2)
        _cur_id = _po_unescape(raw); _in = "id"
        next
      }

      # msgid_plural — ignore (we only want the singular key).
      /^msgid_plural/ { _in = "idp"; next }

      # msgstr[0] — first plural translation; accept only if no msgstr seen yet.
      /^msgstr\[0\][[:space:]]/ {
        if (_cur_str == "") {
          raw = substr($0, 11)
          if (substr(raw, 1, 1) == "\"") raw = substr(raw, 2, length(raw) - 2)
          _cur_str = _po_unescape(raw); _in = "str"
        } else { _in = "" }
        next
      }

      # msgstr[N] for N > 0 — skip.
      /^msgstr\[/ { _in = ""; next }

      # msgstr — the primary translation.
      /^msgstr[[:space:]]/ {
        raw = substr($0, 8)
        if (substr(raw, 1, 1) == "\"") raw = substr(raw, 2, length(raw) - 2)
        _cur_str = _po_unescape(raw); _in = "str"
        next
      }

      # Continuation string — append to whichever field is active.
      /^"/ {
        if (_in == "id" || _in == "str") {
          raw = substr($0, 2, length($0) - 2)
          if (_in == "id") _cur_id  = _cur_id  _po_unescape(raw)
          else             _cur_str = _cur_str _po_unescape(raw)
        }
        next
      }

      END { _flush() }
    ' "$_po_input" > "$_msgunfmt_out"
    rm -f "$_msgunfmt_raw" ${_msgunfmt_conv:+"$_msgunfmt_conv"}

    if [ -s "$_msgunfmt_out" ]; then
      cat "$_msgunfmt_out"
      rm -f "$_msgunfmt_out"
      return
    fi
    rm -f "$_msgunfmt_out"

    # msgunfmt produced no output: fall back to od/awk unless explicitly pinned
    if [ "$MO_READER" = "msgunfmt" ]; then
      _debug "msgunfmt produced no pairs for $mo"
      return
    fi
    _debug "msgunfmt empty, falling back to od/awk for $mo"
  fi

  #
  # od/awk path — pure POSIX, zero extra dependencies
  #
  # Reads the entire file as decimal bytes with one od call, then parses the
  # GNU .mo binary format in a single awk pass. Handles both little-endian
  # (magic 0x950412de) and big-endian (0xde120495) .mo files.
  #
  # GNU .mo layout:
  #   offset  0 : magic                       u32
  #   offset  4 : file format revision        u32 (ignored)
  #   offset  8 : number of strings           u32
  #   offset 12 : orig-string table offset    u32 (N × {len u32, off u32})
  #   offset 16 : trans-string table offset   u32 (N × {len u32, off u32})
  #
  if ! command -v od >/dev/null 2>&1; then
    printf 'error: od is not available for .mo extraction (install it or use msgunfmt)\n' >&2
    return 1
  fi

  # od -A d -t u1: decimal byte addresses + decimal byte values.
  # Collecting bytes by ADDRESS (b[addr+offset] = value) rather than by sequential
  # count means a skipped or malformed od line cannot corrupt subsequent values.
  # This is robust to all BSD od / GNU od formatting differences.
  #
  # Output is captured to a temp file so the shell can inspect the first line
  # for a "#charset:" marker emitted when the file is not UTF-8.  When iconv is
  # available the pairs are converted to UTF-8 via _od_convert_charset_pairs.
  local _od_out
  _od_out=$(mktemp -t rt_od.XXXXXX 2>/dev/null || mktemp)
  od -A d -t u1 "$mo" 2>/dev/null | LC_ALL=C awk -v inc_meta="$INCLUDE_META" '
    BEGIN {
      for (_i = 0; _i < 256; _i++) _ord[sprintf("%c", _i)] = _i
    }

    {
      # $1 is the byte address (decimal); $2..$NF are the byte values.
      # The final od line has only the address (= file size) and no data fields.
      addr = $1 + 0
      if (addr > _fsz) _fsz = addr   # track file size from last address line
      for (i = 2; i <= NF; i++) {
        if ($i ~ /^[0-9]+$/) b[addr + (i - 2)] = $i + 0
      }
    }

    function u32le(o) { return b[o] + b[o+1]*256 + b[o+2]*65536 + b[o+3]*16777216 }
    function u32be(o) { return b[o]*16777216 + b[o+1]*65536 + b[o+2]*256 + b[o+3] }
    function u32(o)   { return _be ? u32be(o) : u32le(o) }

    # Extract NUL-terminated string at byte offset `off`, at most `len` bytes.
    # Stops at the first NUL so only the first plural form is returned.
    function getstr(off, len,    s, j, c) {
      s = ""; j = 0
      while (j < len) {
        c = b[off + j] + 0; j++
        if (c == 0) break
        s = s sprintf("%c", c)
      }
      return s
    }

    # JSON-encode a string (result excludes surrounding quotes).
    # Handles raw bytes: ASCII is passed through, C0 controls are \uXXXX-escaped,
    # and multi-byte UTF-8 sequences are reconstructed and passed through intact.
    # Lone high bytes that are not valid UTF-8 leaders/continuations are escaped
    # as \u00XX so the output is always valid JSON.
    function jstr(s,    o, i, c, v, v2, v3, v4) {
      o = ""; i = 1
      while (i <= length(s)) {
        c = substr(s, i, 1); v = _ord[c]
        if      (c == "\\") { o = o "\\\\"; i++ }
        else if (c == "\"")  { o = o "\\\"";  i++ }
        else if (c == "\n")  { o = o "\\n";    i++ }
        else if (c == "\r")  { o = o "\\r";    i++ }
        else if (c == "\t")  { o = o "\\t";    i++ }
        else if (v < 32)      { o = o sprintf("\\u%04x", v); i++ }
        else if (v < 128)     { o = o c; i++ }
        else if (v >= 240 && v <= 247 && i+3 <= length(s)) {
          # 4-byte UTF-8: 11110xxx 10xxxxxx 10xxxxxx 10xxxxxx
          v2 = _ord[substr(s,i+1,1)]; v3 = _ord[substr(s,i+2,1)]; v4 = _ord[substr(s,i+3,1)]
          if (v2>=128 && v2<=191 && v3>=128 && v3<=191 && v4>=128 && v4<=191) {
            o = o substr(s,i,4); i += 4
          } else { o = o sprintf("\\u%04x", v); i++ }
        } else if (v >= 224 && v <= 239 && i+2 <= length(s)) {
          # 3-byte UTF-8: 1110xxxx 10xxxxxx 10xxxxxx
          v2 = _ord[substr(s,i+1,1)]; v3 = _ord[substr(s,i+2,1)]
          if (v2>=128 && v2<=191 && v3>=128 && v3<=191) {
            o = o substr(s,i,3); i += 3
          } else { o = o sprintf("\\u%04x", v); i++ }
        } else if (v >= 194 && v <= 223 && i+1 <= length(s)) {
          # 2-byte UTF-8: 110xxxxx 10xxxxxx (0xC0/0xC1 are overlong, reject)
          v2 = _ord[substr(s,i+1,1)]
          if (v2>=128 && v2<=191) {
            o = o substr(s,i,2); i += 2
          } else { o = o sprintf("\\u%04x", v); i++ }
        } else {
          # Lone high byte or invalid UTF-8 leader — escape it
          o = o sprintf("\\u%04x", v); i++
        }
      }
      return o
    }

    END {
      if (_fsz < 28) {
        print "error: .mo file too small to contain a valid header" > "/dev/stderr"
        exit 1
      }

      mle = u32le(0); mbe = u32be(0)
      # LE magic: bytes [de 12 04 95] → native u32 on LE host = 0x950412de = 2500072158
      # BE magic: same bytes read BE  → 0xde120495 = 3725722261  (swapped)
      if      (mle == 2500072158) _be = 0
      else if (mbe == 2500072158) _be = 1
      else {
        printf "error: not a GNU .mo file (magic=%d)\n", mle > "/dev/stderr"
        exit 1
      }

      nstr = u32(8); oo = u32(12); to = u32(16)

      # Detect charset from the PO header entry (empty msgid → olen == 0).
      # If the file is not UTF-8 / ASCII, emit a "#charset:X" marker as the
      # first output line so the shell wrapper can route through iconv.
      _charset = "UTF-8"
      for (_ci = 0; _ci < nstr; _ci++) {
        if (u32(oo + _ci*8) == 0) {
          _hdr_tlen = u32(to + _ci*8)
          _hdr_tpos = u32(to + _ci*8 + 4)
          _hdr = getstr(_hdr_tpos, _hdr_tlen)
          if (match(_hdr, /charset=/)) {
            _cs = substr(_hdr, RSTART + 8)
            _nl = index(_cs, "\n"); if (_nl == 0) _nl = length(_cs) + 1
            _charset = substr(_cs, 1, _nl - 1)
            while (length(_charset) > 0) {
              _lc = substr(_charset, length(_charset), 1)
              if (_lc=="\r"||_lc==" "||_lc=="\t"||_lc=="\""||_lc=="\\")
                _charset = substr(_charset, 1, length(_charset)-1)
              else break
            }
          }
          break
        }
      }
      _csnorm = _charset
      gsub(/[-]/, "", _csnorm)   # strip hyphens for comparison
      # Emit marker when charset requires post-processing
      if (_csnorm != "UTF8"    && _csnorm != "utf8"    &&
          _csnorm != "ASCII"   && _csnorm != "ascii"   &&
          _csnorm != "USASCII" && _csnorm != "usascii" &&
          _csnorm != "UTF7"    && _csnorm != "utf7"    &&
          _csnorm != "ANSIX341968" && _csnorm != "" ) {
        print "#charset:" _charset
      }

      for (i = 0; i < nstr; i++) {
        olen = u32(oo + i*8); opos = u32(oo + i*8 + 4)
        tlen = u32(to + i*8); tpos = u32(to + i*8 + 4)
        if ((olen == 0 && !inc_meta) || tlen == 0) continue
        mid = getstr(opos, olen)
        mst = getstr(tpos, tlen)
        if ((mid == "" && !inc_meta) || mst == "") continue
        print "\"" jstr(mid) "\"\t\"" jstr(mst) "\""
      }
    }
  ' > "$_od_out"

  # Inspect first line for charset marker; route through iconv when present
  local _od_first _od_charset
  _od_first=$(head -1 "$_od_out" 2>/dev/null || true)
  case "$_od_first" in
    "#charset:"*)
      _od_charset="${_od_first#\#charset:}"
      if command -v iconv >/dev/null 2>&1; then
        _debug "od charset=$_od_charset, converting via iconv"
        tail -n +2 "$_od_out" | _od_convert_charset_pairs "$_od_charset" "$INCLUDE_META"
      else
        _debug "od charset=$_od_charset; iconv not available, code points may differ for non-Latin-1"
        tail -n +2 "$_od_out"
      fi ;;
    *)
      cat "$_od_out" ;;
  esac
  rm -f "$_od_out"
}

#
# _want_color: exits 0 when color output should be used
#
_want_color() {
  case "${COLOR_MODE:-auto}" in
    always) return 0 ;;
    never)  return 1 ;;
    auto)
      [ -n "${NO_COLOR:-}" ] && return 1
      [ -t 1 ] && return 0
      return 1
      ;;
  esac
  return 1
}

