# Dispatch theme by name
# Usage: _apply_theme "aurora" "$_E"
_apply_theme() {
  local name="$1"; shift
  local e="$1"
  case "$name" in
    aurora|cyberpunk|neon|sakura|tokyonight|classic|ocean|mars|jungle|phosphor|nocolor) ;;
    *) name="aurora" ;;
  esac

  _debug "using theme: $name"

  # shellcheck disable=SC2086  # intentional: $name is whitelisted above; dynamic dispatch
  _theme_$name "$e"
}

# Apply chosen theme (or zero out all vars if color is disabled).
# Expects a function _want_color to exist elsewhere in your script.
if _want_color; then
  _E=$(printf '\033')
  _apply_theme "${THEME:-jungle}" "$_E"
else
  _theme_nocolor
fi

#
# Read tab-separated JSON pairs from stdin, emit PO-like text (msgunfmt style).
# msgctxt is recovered from the \x04-encoded msgid where present.
#
_fmt_raw() {
  awk \
    -v inc_meta="$INCLUDE_META" \
    -v ck="$C_K_ID" \
    -v cv="$C_K_ST" \
    -v cx="$C_K_CX" \
    -v cr="$C_RST" \
    '
    function junesc(s,    o, i, c, n) {
      o = ""; i = 1
      while (i <= length(s)) {
        c = substr(s, i, 1)
        if (c == "\\") {
          n = substr(s, i+1, 1)
          if      (n == "n")  { o = o "\n"; i += 2 }
          else if (n == "t")  { o = o "\t"; i += 2 }
          else if (n == "r")  { o = o "\r"; i += 2 }
          else if (n == "\\") { o = o "\\"; i += 2 }
          else if (n == "\"") { o = o "\""; i += 2 }
          else if (n == "u")  {
            h = substr(s, i+2, 4)
            # Portable hex-to-decimal: walk the 4 hex digits manually.
            # (strtonum is gawk-only; not available in BSD awk or nawk)
            hv = 0
            for (_hi = 1; _hi <= 4; _hi++) {
              _hc = substr(h, _hi, 1)
              if      (_hc >= "0" && _hc <= "9") _hd = _hc + 0
              else if (_hc >= "a" && _hc <= "f") _hd = _hc == "a" ? 10 : _hc == "b" ? 11 : _hc == "c" ? 12 : _hc == "d" ? 13 : _hc == "e" ? 14 : 15
              else if (_hc >= "A" && _hc <= "F") _hd = _hc == "A" ? 10 : _hc == "B" ? 11 : _hc == "C" ? 12 : _hc == "D" ? 13 : _hc == "E" ? 14 : 15
              else _hd = 0
              hv = hv * 16 + _hd
            }
            o = o sprintf("%c", hv); i += 6
          }
          else { o = o n; i += 2 }
        } else { o = o c; i++ }
      }
      return o
    }

    {
      t = index($0, "\t")
      if (t == 0) next
      ri = substr($0, 1, t-1)
      rs = substr($0, t+1)
      # strip surrounding double-quotes from each JSON string
      mid = junesc(substr(ri, 2, length(ri)-2))
      mst = junesc(substr(rs, 2, length(rs)-2))
      if ((mid == "" && !inc_meta) || mst == "") next

      # PO header entry (empty msgid): format with continuation lines so each
      # metadata field appears on its own quoted line, matching msgunfmt output.
      if (mid == "") {
        printf "%smsgid%s \"\"\n",  ck, cr
        printf "%smsgstr%s \"\"\n", cv, cr
        n = split(mst, _hlines, "\n")
        for (_hi = 1; _hi <= n; _hi++) {
          if (_hlines[_hi] != "") printf "\"%s\\n\"\n", _hlines[_hi]
        }
        printf "\n"
        next
      }

      # recover msgctxt (\x04 separator)
      ctxt = ""
      if (index(mid, "\004") > 0) {
        ctxt = substr(mid, 1, index(mid, "\004")-1)
        mid  = substr(mid, index(mid, "\004")+1)
        if (!inc_meta) next
        printf "%smsgctxt%s \"%s\"\n", cx, cr, ctxt
      }

      printf "%smsgid%s \"%s\"\n",  ck, cr, mid
      printf "%smsgstr%s \"%s\"\n", cv, cr, mst
      printf "\n"
    }
  '
}

