#
# Themes
#
# Color roles:
#   raw    C_K_ID C_K_ST C_K_CX           — msgid / msgstr / msgctxt keywords
#   json   C_J_BR C_J_KY C_J_SV           — brackets / keys / strings
#   yaml   (reuses C_J_BR C_J_KY C_J_SV)  — same roles as json
#   human  C_H_SRC C_H_TRR C_H_ARR        — source text / translation / translation-label accent
#          C_H_HDR_BDR C_H_HDR_KEY        — header border / field labels
#          C_H_HDR_VAL C_H_HDR_ACT        — field values / app-name accent
#   all    C_RST                          — reset
#

# Aurora: vivid greens, violet, sky blue — the colors of actual aurora borealis.
_theme_aurora() {
  local e="$1"
  _palette_init "$e"

  # raw
  C_K_ID="${COL_256_BOLD_VIOLET}"           # msgid   — aurora violet/purple
