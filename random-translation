#!/usr/bin/env bash

# Production-quality tool to pick a random installed .mo file for one or more languages
# and output translations.
#
# Should work on macOS, Linux, and all *nix OS'es. By default it auto-builds
# a deep cache on first run, then uses cached lookups thereafter.
#
# Features
#  - discovery strategies: auto, quick, indexed, targeted, deep, cached
#  - cache behavior control: read, write, none
#  - caching with TTL and refresh (only when cache-mode is read/write)
#  - flexible output: normal|json|yaml|filename
#  - return N random msgstr strings (-n N)
#  - robust locale matching (es, es_ES, es-ES, es_ES.UTF-8)
#  - discovery roots override (--roots)
#  - debug shows what each strategy and cache decision is doing
#  - version via --version
#
# Exit codes
#  0 success
#  1 usage / argument error
#  2 missing tools for extraction
#  3 no matches found

set -euo pipefail

# Restore default SIGPIPE handling so the script exits when a downstream consumer closes the pipe
trap - PIPE 2>/dev/null || true

VERSION="1.2.0"

usage() {
  cat <<'EOF'
Usage: random-translation [options] LANGS...

  LANGS may be one or more language codes (space or comma separated).

  Examples:
    - Single codes: es tr el
    - Comma list: "es,el,tr"
    - Locale variant: es_ES

  Default behavior: auto deep-scan + cache build on first run, cached lookup thereafter.

Options
  --roots PATHS       Colon-separated roots to search (overrides default roots)
  --strategy STR      Discovery strategy: auto|quick|indexed|targeted|deep|cached
  --cache-mode MODE   Cache behavior: read|write|none
  --refresh           Force rebuild of the .mo list (applies when cache-mode is write or when using transient cache)
  --ttl SECS          Cache TTL in seconds (default 3600)
  --debug             Print debug information showing what each strategy and cache decision does
  -H, --header        Include PO header metadata in output (default: hidden)
  --meta              Include metadata entries in normal output (e.g. msgctxt)
  --color WHEN        Colorize output: auto|always|never (default: auto)
  --no-color          Alias for --color never
  -n N                Print N random msgstr strings only (useful for screensavers)
  --output MODE       Output mode: normal|json|yaml|filename  (default: normal)
  --cache-stats       Print cache stats (entries, age, size) then exit
  --cache-init        Build the cache (deep scan + write) and exit
  --version           Print version and exit
  --dry-run           Print the path that would be read and exit (alias for --output filename)
  -h, --help          Show this help
EOF
  exit 1
}

# Defaults
DEFAULT_LOCALE_DIRS="/usr/share/locale:/usr/local/share/locale:/usr/share/locale-langpack:/usr/lib/locale:/Library/Locale:/System/Library/Frameworks/Python.framework/Versions/Current/Resources/locale"
STRATEGY="auto"
STRATEGY_SET=0
LOCALE_DIRS="${LOCALE_DIRS:-$DEFAULT_LOCALE_DIRS}"
CACHE_MODE="read" # read | write | none; auto mode overrides as needed
CACHE_MODE_SET=0 # becomes 1 if user explicitly passed --cache-mode
REFRESH=0
DEBUG=0
INCLUDE_HEADER=0
INCLUDE_META=0
COLOR_MODE="auto"
N_STRINGS=0
OUTPUT_MODE="normal" # normal | json | yaml | filename
CACHE_STATS=0
TTL=3600
ROOTS=""
LANGS=""
CACHE_INIT=0

# Print missing-argument error and show usage
_missing_arg() { echo "error: missing value for $1" >&2; usage; }

# Return the next argv value or call _missing_arg
_getval() {
  flag="$1"; val="${2-}"
  [ -n "${val-}" ] || _missing_arg "$flag"
  # reject values that look like flags (optional stricter behavior)
  case "$val" in -*) _missing_arg "$flag" ;; esac
  printf '%s' "$val"
}

# Parse args (compact, safe under set -u)
while [ $# -gt 0 ]; do
  case "$1" in
    --roots)      ROOTS="$(_getval --roots "${2-}")"; shift 2 ;;
    --strategy)   STRATEGY="$(_getval --strategy "${2-}")"; STRATEGY_SET=1; shift 2 ;;
    --cache-mode) CACHE_MODE="$(_getval --cache-mode "${2-}")"; CACHE_MODE_SET=1; shift 2 ;;
    --refresh)    REFRESH=1; shift ;;
    --ttl)        TTL="$(_getval --ttl "${2-}")"; shift 2 ;;
    --debug)      DEBUG=1; shift ;;
    -H|--header)  INCLUDE_HEADER=1; shift ;;
    --meta)       INCLUDE_META=1; shift ;;
    --color)      COLOR_MODE="$(_getval --color "${2-}")"; shift 2 ;;
    --no-color)   COLOR_MODE="never"; shift ;;
    -n)           N_STRINGS="$(_getval -n "${2-}")"; shift 2 ;;
    --output)     OUTPUT_MODE="$(_getval --output "${2-}")"; shift 2 ;;
    --cache-stats) CACHE_STATS=1; shift ;;
    --version)    printf '%s\n' "$VERSION"; exit 0 ;;
    --dry-run)    OUTPUT_MODE="filename"; shift ;;
    --cache-init) CACHE_INIT=1; shift ;;
    -h|--help)    usage ;;
    --) shift; break ;;
    -*)
      echo "Unknown option: $1" >&2; usage
      ;;
    *)
      LANGS="${LANGS} ${1}"; shift
      ;;
  esac
done

# Merge env var LANG_CODES if present
if [ -n "${LANG_CODES:-}" ]; then
  LANGS="${LANGS} ${LANG_CODES}"
fi

#
# Container-aware HOME / XDG bootstrap
#
# This block ensures the script behaves correctly when launched from GUI apps
# (screensavers, launchd, etc.) that may provide a minimal or containerized HOME.
# It:
#  - tries to resolve a real system home (getent/dscl/ /etc/passwd) when HOME is unset
#  - if HOME looks containerized, prefers the system home when available
#  - sets platform-appropriate XDG default (macOS -> ~/Library/Caches, others -> ~/.cache)
#  - leaves HOME alone if no better candidate is found
#

# helper: get home from system user DB (portable)
_get_system_home() {
  if command -v getent >/dev/null 2>&1; then
    getent passwd "$(id -u)" 2>/dev/null | cut -d: -f6 || true
    return
  fi

  if command -v dscl >/dev/null 2>&1; then
    user="$(id -un 2>/dev/null || true)"
    if [ -n "$user" ]; then
      dscl . -read "/Users/$user" NFSHomeDirectory 2>/dev/null | awk '{print $2}' || true
      return
    fi
  fi

  awk -F: -v uid="$(id -u)" '$3==uid {print $6; exit}' /etc/passwd 2>/dev/null || true
}

# If HOME unset, try to populate it from system DB or sensible fallback
if [ -z "${HOME:-}" ]; then
  syshome="$(_get_system_home)"
  HOME="${syshome:-}"
  if [ -z "$HOME" ]; then
    HOME="/Users/$(whoami 2>/dev/null || echo user)"
    [ -d "$HOME" ] || HOME="/home/$(whoami 2>/dev/null || echo user)"
  fi
  export HOME
fi

# If HOME looks like a container/sandbox path, try to prefer the system home
case "${HOME:-}" in
  */Library/Containers/*|*/Containers/*|*/private/var/containers/*|*/Library/Application\ Support/*)
    syshome="$(_get_system_home)"
    if [ -n "$syshome" ] && [ "$syshome" != "$HOME" ] && [ -d "$syshome" ]; then
      HOME="$syshome"
      export HOME
    fi
    ;;
esac

# Platform-aware default XDG cache location
OS="$(uname -s 2>/dev/null || echo unknown)"
case "$OS" in
  Darwin*) DEFAULT_XDG="$HOME/Library/Caches" ;;
  *)       DEFAULT_XDG="$HOME/.cache" ;;
esac
XDG_CACHE_HOME_USER_SET=0
if [ -n "${XDG_CACHE_HOME:-}" ]; then
  XDG_CACHE_HOME_USER_SET=1
fi
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-$DEFAULT_XDG}"

# Respect XDG_DATA_HOME for user-local data (common place for per-user locale files).
# Default per-spec: ${XDG_DATA_HOME:-$HOME/.local/share}
export XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
# Ensure LOCALE_DIRS includes $XDG_DATA_HOME/locale so per-user installs are discovered.
if [ -n "${XDG_DATA_HOME:-}" ]; then
  case ":${LOCALE_DIRS:-}:" in
    *":${XDG_DATA_HOME}/locale:") ;;
    *) LOCALE_DIRS="${LOCALE_DIRS}:${XDG_DATA_HOME}/locale" ;;
  esac
fi

_human_size() {
  local bytes="$1"
  awk -v b="${bytes}" 'BEGIN {
    split("B KiB MiB GiB TiB", u, " ")
    i = 1
    while (b >= 1024 && i < 5) { b /= 1024; i++ }
    if (i == 1) printf "%d %s", b, u[i]
    else printf "%.1f %s", b, u[i]
  }'
}

# Track explicit cache path overrides supplied by the environment.
CACHE_FILE_EXPLICIT=0
CACHE_DIR_EXPLICIT=0
[ "${CACHE_FILE+x}" = "x" ] && [ -n "${CACHE_FILE:-}" ] && CACHE_FILE_EXPLICIT=1
[ "${CACHE_DIR+x}" = "x" ] && [ -n "${CACHE_DIR:-}" ] && CACHE_DIR_EXPLICIT=1

# Ensure CACHE_DIR has a sensible default before any use (avoids set -u errors)
CACHE_DIR="${CACHE_DIR:-${XDG_CACHE_HOME}/random-translation}"
CACHE_FILE="${CACHE_FILE:-${CACHE_DIR}/mos.cache}"

# Resolve cache file from multiple canonical locations (respect explicit overrides)
preferred_cache=""
if [ "$CACHE_FILE_EXPLICIT" -eq 1 ]; then
  preferred_cache="$CACHE_FILE"
elif [ "$CACHE_DIR_EXPLICIT" -eq 1 ]; then
  preferred_cache="${CACHE_DIR}/mos.cache"
elif [ "$XDG_CACHE_HOME_USER_SET" -eq 1 ]; then
  CACHE_DIR="${XDG_CACHE_HOME}/random-translation"
  preferred_cache="${CACHE_DIR}/mos.cache"
elif [ -n "${CACHE_FILE:-}" ] && [ -f "${CACHE_FILE}" ]; then
  preferred_cache="$CACHE_FILE"
fi

if [ -n "$preferred_cache" ]; then
  CACHE_FILE="$preferred_cache"
else
  candidates=(
    "${CACHE_FILE:-}"
    "${CACHE_DIR:-}/mos.cache"
    "${XDG_CACHE_HOME:-$DEFAULT_XDG}/random-translation/mos.cache"
    "$HOME/Library/Caches/random-translation/mos.cache"
    "$HOME/.cache/random-translation/mos.cache"
    "/var/cache/random-translation/mos.cache"
  )

  CACHE_FILE=""
  for c in "${candidates[@]}"; do
    [ -z "$c" ] && continue
    if [ -f "$c" ]; then
      CACHE_FILE="$c"
      break
    fi
  done

  if [ -z "$CACHE_FILE" ]; then
    if [ "$OS" = "Darwin" ]; then
      CACHE_DIR="${CACHE_DIR:-${XDG_CACHE_HOME:-$HOME/Library/Caches}/random-translation}"
    else
      CACHE_DIR="${CACHE_DIR:-${XDG_CACHE_HOME:-$DEFAULT_XDG}/random-translation}"
    fi
    CACHE_FILE="${CACHE_FILE:-$CACHE_DIR/mos.cache}"
    mkdir -p "$CACHE_DIR" 2>/dev/null || true
  fi
fi

# Ensure cache dir exists (no-op if already created); tolerate restricted envs
mkdir -p "${CACHE_DIR:-}" 2>/dev/null || true

# System-wide fallback
SYSTEM_CACHE="/var/cache/random-translation/mos.cache"
if [ "$CACHE_FILE_EXPLICIT" -eq 0 ]; then
  if [ -z "${CACHE_FILE:-}" ] || [ ! -f "${CACHE_FILE:-}" ]; then
    if [ -f "$SYSTEM_CACHE" ]; then
      CACHE_FILE="$SYSTEM_CACHE"
    fi
  fi
fi

# Keep cache dir aligned with the chosen cache file path.
if [ -n "${CACHE_FILE:-}" ]; then
  CACHE_DIR="$(dirname "$CACHE_FILE")"
fi

_mtime_epoch() {
  local f="$1"
  if stat -f %m "$f" >/dev/null 2>&1; then
    stat -f %m "$f"
  else
    stat -c %Y "$f" 2>/dev/null || echo 0
  fi
}

_cache_index_present() {
  local d="$1" f
  for f in "$d"/mos.cache.lang.*; do
    [ -f "$f" ] || continue
    case "$f" in
      *.count) continue ;;
    esac
    [ -s "$f" ] && return 0
  done
  return 1
}

_print_cache_missing() {
  local ctx="$1"
  echo "error: $ctx expects an existing cache file: ${CACHE_FILE:-}" >&2
  if _cache_index_present "${CACHE_DIR:-}"; then
    echo "Found language index files in ${CACHE_DIR:-}, but master cache file is missing." >&2
  fi
  echo "Hint: rebuild cache with:" >&2
  echo "  ./random-translation --strategy indexed --cache-mode write --refresh LANG" >&2
  echo "or:" >&2
  echo "  ./random-translation --strategy deep --cache-mode write --refresh LANG" >&2
}

# _print_cache_stats: Display cache metrics with maximal portability
#
# Portability guarantees:
#   - Works on GNU/Linux, BSD (FreeBSD/OpenBSD/NetBSD), macOS, WSL, minimal containers
#   - Graceful degradation when utilities are missing (du, stat, awk, etc.)
#   - POSIX sh compliant except for local variables (required for recursion safety)
#   - Handles both GNU and BSD stat/du flag differences automatically
#   - No bashisms in critical paths (arrays $() safe, no [[ ]], no <<<)
#
# Size terminology:
#   - "Logical size" = byte count of file contents (what wc -c reports)
#   - "Physical size" = actual disk blocks allocated (includes metadata, slack space)
#
# Units: IEC binary (KiB, MiB, GiB) for precision — 1 KiB = 1024 bytes
_print_cache_stats() {
  local count now mtime age idx_files=0 idx_total=0 f c size_bytes size_human
  local dir_logical_bytes dir_logical_human dir_physical_bytes dir_physical_human

  [ -f "${CACHE_FILE:-}" ] || return 1

  mtime=$(_mtime_epoch "${CACHE_FILE}")
  now=$(date +%s)
  age=$((now - mtime))
  count=$(wc -l <"${CACHE_FILE}" 2>/dev/null || echo 0)

  size_bytes=$(wc -c <"${CACHE_FILE}" 2>/dev/null | tr -d ' ' || echo 0)
  size_human=$(_human_size "$size_bytes")

  dir_logical_bytes=0
  dir_physical_bytes=""

  if command -v du >/dev/null 2>&1; then
    # Logical size: apparent bytes (GNU -b, BSD -A)
    dir_logical_bytes=$(du -sb "${CACHE_DIR}" 2>/dev/null | awk '{print $1}')
    if [ -z "$dir_logical_bytes" ]; then
      # BSD/macOS: -A = apparent size, multiply 1K blocks by 1024
      dir_logical_bytes=$(du -sAk "${CACHE_DIR}" 2>/dev/null | awk '{print $1}')
      dir_logical_bytes=$((dir_logical_bytes * 1024))
    fi

    # Physical size: disk blocks allocated (GNU --block-size=1, BSD -k)
    dir_physical_bytes=$(du -s --block-size=1 "${CACHE_DIR}" 2>/dev/null | awk '{print $1}')
    if [ -z "$dir_physical_bytes" ]; then
      # BSD/macOS: -k gives 1024-byte blocks
      dir_physical_bytes=$(du -sk "${CACHE_DIR}" 2>/dev/null | awk '{print $1}')
      dir_physical_bytes=$((dir_physical_bytes * 1024))
    fi
  else
    # Fallback: manual logical sum; physical unavailable without du
    while IFS= read -r -d '' f; do
      local sz
      sz=$(stat -c %s "$f" 2>/dev/null || stat -f %z "$f" 2>/dev/null || echo 0)
      dir_logical_bytes=$((dir_logical_bytes + sz))
    done < <(find "${CACHE_DIR}" -type f -print0 2>/dev/null)
  fi

  dir_logical_human=$(_human_size "$dir_logical_bytes")

  if [ -n "$dir_physical_bytes" ]; then
    dir_physical_human=$(_human_size "$dir_physical_bytes")
  else
    dir_physical_bytes="N/A"
    dir_physical_human="N/A"
  fi

  printf 'Cache file: %s
Entries: %s
Age seconds: %s
Cache file size: %s (%s bytes)
Cache directory (logical): %s (%s bytes)
Disk usage: %s (%s bytes)
'     "${CACHE_FILE}" "$count" "$age" "$size_human" "$size_bytes" \
      "$dir_logical_human" "$dir_logical_bytes" \
      "$dir_physical_human" "$dir_physical_bytes"

  for f in "${CACHE_DIR}"/mos.cache.lang.*; do
    [ -f "$f" ] || continue
    case "$f" in
      *.count)
        c=$(tr -d '[:space:]' <"$f" 2>/dev/null || echo 0)
        case "$c" in ''|*[!0-9]*) c=0 ;; esac
        idx_total=$((idx_total + c))
        ;;
      *) [ -s "$f" ] && idx_files=$((idx_files + 1)) ;;
    esac
  done

  printf 'Language indexes: %s
Indexed entries: %s
' "$idx_files" "$idx_total"
}

# Debug trace of chosen cache
if [ "${DEBUG:-0}" -eq 1 ]; then
  echo "DEBUG: resolved CACHE_DIR=${CACHE_DIR:-}" >&2
  echo "DEBUG: resolved CACHE_FILE=${CACHE_FILE:-}" >&2
fi

# --cache-stats should work without LANGS
if [ "${CACHE_STATS:-0}" -eq 1 ]; then
  if _print_cache_stats; then
    exit 0
  else
    echo "No cache found yet at: ${CACHE_FILE:-}" >&2
    echo "Run once with languages to auto-build it, for example:" >&2
    echo "  random-translation sv,fi,pl" >&2
    exit 0
  fi
fi

# If strategy cached and no LANGS, show cache status (instead of falling through to usage).
if [ "${STRATEGY:-}" = "cached" ] && [ -z "${LANGS:-}" ]; then
  if _print_cache_stats; then
    echo "Note: --strategy cached implies --cache-mode read; showing cache status." >&2
    echo >&2
    echo "To sample translations, provide one or more LANGS, e.g.:" >&2
    echo "  random-translation -n 1 el tr es" >&2
    exit 0
  else
    _print_cache_missing "--strategy cached"
    exit 3
  fi
fi

# Normalize languages: convert commas to spaces, trim
LANGS=$(printf '%s\n' "$LANGS" | awk 'BEGIN{ORS=" "} {gsub(/,/," "); for(i=1;i<=NF;i++) print $i}' | sed 's/^ *//; s/ *$//')

# Only require LANGS when the user actually needs to select translations.
# Allow --cache-stats and --strategy cached to run without LANGS.
if [ -z "$LANGS" ] && [ "${CACHE_STATS:-0}" -eq 0 ] && [ "${STRATEGY:-}" != "cached" ] && [ "${CACHE_INIT:-0}" -eq 0 ]; then
  echo "Please specify one or more languages." >&2
  echo "Use --help for usage instructions." >&2
  exit 1
fi

if [ "${CACHE_INIT:-0}" -eq 1 ]; then
  if [ "${STRATEGY_SET:-0}" -eq 1 ] || [ "${CACHE_MODE_SET:-0}" -eq 1 ]; then
    echo "error: --cache-init cannot be combined with --strategy or --cache-mode" >&2
    exit 1
  fi
  STRATEGY="deep"
  CACHE_MODE="write"
  STRATEGY_SET=1
  CACHE_MODE_SET=1
  REFRESH=1
fi

# Resolve default interface:
#   - no explicit strategy/cache-mode => auto mode (deep build first, cached thereafter)
#   - explicit strategy without cache-mode keeps old behavior: cached -> read, others -> none
#   - explicit cache-mode without strategy picks a sensible companion strategy
if [ "${STRATEGY_SET:-0}" -eq 0 ] && [ "${CACHE_MODE_SET:-0}" -eq 1 ]; then
  case "$CACHE_MODE" in
    read)  STRATEGY="cached" ;;
    write) STRATEGY="deep" ;;
    none)  STRATEGY="quick" ;;
  esac
fi

if [ "${STRATEGY_SET:-0}" -eq 1 ] && [ "${CACHE_MODE_SET:-0}" -eq 0 ]; then
  case "$STRATEGY" in
    cached) CACHE_MODE="read" ;;
    auto) ;;
    *) CACHE_MODE="none" ;;
  esac
fi

if [ "${STRATEGY:-}" = "auto" ]; then
  if [ "${CACHE_MODE_SET:-0}" -eq 1 ]; then
    echo "error: --strategy auto does not accept an explicit --cache-mode" >&2
    echo "Hint: omit --cache-mode for automatic behavior, or choose a manual strategy." >&2
    exit 1
  fi
  if [ "${REFRESH:-0}" -eq 1 ] || [ ! -f "${CACHE_FILE:-}" ]; then
    STRATEGY="deep"
    CACHE_MODE="write"
    [ "${DEBUG:-0}" -eq 1 ] && echo "DEBUG: auto mode -> deep write" >&2
  else
    STRATEGY="cached"
    CACHE_MODE="read"
    [ "${DEBUG:-0}" -eq 1 ] && echo "DEBUG: auto mode -> cached read" >&2
  fi
fi

# Validate strategy-specific options
if [ "${STRATEGY:-}" = "targeted" ] && [ -z "${ROOTS:-}" ]; then
  echo "error: --strategy targeted requires --roots to be set (colon-separated list of directories)." >&2
  echo >&2
  echo "Usage example:" >&2
  echo "  ./random-translation --strategy targeted --roots '/usr/share/locale:/usr/local/share/locale' el" >&2
  exit 1
fi

if [ "${STRATEGY:-}" = "cached" ]; then
  if [ "${CACHE_MODE:-}" != "read" ]; then
    echo "error: --strategy cached only supports --cache-mode read" >&2
    echo "Hint: use --strategy indexed|deep with --cache-mode write to rebuild cache." >&2
    exit 1
  fi
  if [ "${REFRESH:-0}" -eq 1 ]; then
    echo "error: --refresh cannot be used with --strategy cached" >&2
    echo "Hint: rebuild with --strategy indexed|deep --cache-mode write --refresh LANG." >&2
    exit 1
  fi
fi

# Validate CACHE_MODE, STRATEGY, and OUTPUT_MODE
case "$CACHE_MODE" in
  read|write|none) ;;
  *)
    echo "error: invalid --cache-mode value: $CACHE_MODE" >&2
    usage
    ;;
esac

case "$STRATEGY" in
  auto|quick|indexed|targeted|deep|cached) ;;
  *)
    echo "error: invalid --strategy value: $STRATEGY" >&2
    usage
    ;;
esac

case "$OUTPUT_MODE" in
  normal|json|yaml|filename) ;;
  *)
    echo "error: invalid --output value: $OUTPUT_MODE" >&2
    usage
    ;;
esac

case "$COLOR_MODE" in
  auto|always|never) ;;
  *)
    echo "error: invalid --color value: $COLOR_MODE" >&2
    usage
    ;;
esac

append_dir() {
  local new="$1"
  case ":$LOCALE_DIRS:" in *":$new:"*) ;; *) LOCALE_DIRS="${LOCALE_DIRS}:$new" ;; esac
}

# If user provided --roots, add them to LOCALE_DIRS
if [ -n "$ROOTS" ]; then
  IFS=':' read -r -a _roots <<< "$ROOTS"
  for r in "${_roots[@]}"; do
    [ -n "$r" ] && append_dir "$r"
  done
fi

# Discovery dispatcher with debug messages
discover_mo_list() {
  local strategy="$1"; local cache="$2"; local debug="$3"; local roots="$4"
  : >"$cache"

  case "$strategy" in
    quick)
      [ "$debug" -eq 1 ] && echo "DEBUG: quick strategy scanning common roots" >&2
      for d in /usr/share/locale /usr/local/share/locale /opt/homebrew/share/locale $roots; do
        [ -z "$d" ] && continue
        [ -d "$d" ] || continue
        [ "$debug" -eq 1 ] && echo "DEBUG: find under $d (shallow)" >&2
        find "$d" -type f -path '*/LC_MESSAGES/*.mo' -maxdepth 6 2>/dev/null >>"$cache" || true
      done
      ;;

    indexed)
      [ "$debug" -eq 1 ] && echo "DEBUG: indexed strategy using mdfind/locate if available" >&2
      if command -v mdfind >/dev/null 2>&1; then
        [ "$debug" -eq 1 ] && echo "DEBUG: using mdfind" >&2
        mdfind "kMDItemFSName == '*.mo'c" 2>/dev/null | grep -i '\.mo$' >>"$cache" || true
      elif command -v locate >/dev/null 2>&1; then
        [ "$debug" -eq 1 ] && echo "DEBUG: using locate" >&2
        locate '*.mo' 2>/dev/null | grep -i '\.mo$' >>"$cache" || true
      else
        [ "$debug" -eq 1 ] && echo "DEBUG: no indexer found; falling back to limited find" >&2
        for d in /usr/share /usr/local /opt /Applications; do
          [ -d "$d" ] || continue
          find "$d" -type f -iname '*.mo' -maxdepth 6 2>/dev/null >>"$cache" || true
        done
      fi
      ;;

    targeted)
      [ "$debug" -eq 1 ] && echo "DEBUG: targeted strategy scanning roots: $roots" >&2
      IFS=':' read -r -a _roots <<< "$roots"
      for d in "${_roots[@]}"; do
        [ -z "$d" ] && continue
        [ -d "$d" ] || continue
        [ "$debug" -eq 1 ] && echo "DEBUG: find under $d (targeted)" >&2
        find "$d" -type f -path '*/LC_MESSAGES/*.mo' -maxdepth 6 2>/dev/null >>"$cache" || true
      done
      ;;

    deep)
      [ "$debug" -eq 1 ] && echo "DEBUG: deep strategy full scan (may be slow)" >&2
      find / -maxdepth 8 2>/dev/null \( -path '/System' -o -path '/private/var' -o -path '/Volumes' -o -path '/proc' \) -prune -o -type f -iname '*.mo' -print | grep -i '\.mo$' >>"$cache" || true
      ;;

    cached)
      [ "$debug" -eq 1 ] && echo "DEBUG: cached strategy: using existing cache only" >&2
      # do nothing
      ;;

    *)
      echo "error: unknown strategy: $strategy" >&2
      return 1
      ;;
  esac

  if [ -s "$cache" ]; then
    awk '!seen[$0]++' "$cache" >"${cache}.uniq" || true
    mv "${cache}.uniq" "$cache"
  fi
  return 0
}

# Compact, correct cache-mode logic
rebuild_cache=0
SKIP_LOCALE_FILTER=0   # when cache-mode=none we will skip LOCALE_DIRS filtering

case "$CACHE_MODE" in
  none)
    # Completely ignore cache: no read, no write, no TTL, no fallback
    [ "$DEBUG" -eq 1 ] && echo "DEBUG: cache-mode=none → ignoring cache entirely" >&2
    rebuild_cache=1
    SKIP_LOCALE_FILTER=1
    ;;

  read)
    # Read-only: rebuild only if --refresh
    if [ "$REFRESH" -eq 1 ]; then
      rebuild_cache=1
    else
      if [ ! -f "${CACHE_FILE:-}" ]; then
        _print_cache_missing "--cache-mode read"
        exit 3
      fi
      [ "$DEBUG" -eq 1 ] && echo "DEBUG: cache-mode=read → using existing cache" >&2
    fi
    ;;

  write)
    # Write mode: rebuild if refresh, missing, or TTL expired
    if [ "$REFRESH" -eq 1 ] || [ ! -f "${CACHE_FILE:-}" ]; then
      rebuild_cache=1
    else
      now=$(date +%s)
      if stat -f %m "${CACHE_FILE}" >/dev/null 2>&1; then
        mtime=$(stat -f %m "${CACHE_FILE}")
      else
        mtime=$(stat -c %Y "${CACHE_FILE}" 2>/dev/null || echo 0)
      fi
      age=$((now - mtime))
      [ "$age" -ge "$TTL" ] && rebuild_cache=1

      [ "$DEBUG" -eq 1 ] && echo "DEBUG: cache-mode=write → age=$age TTL=$TTL rebuild=$rebuild_cache" >&2
    fi
    ;;
esac

#
# Language index: build and use per-language index files for fast lookup.
#
# An index file (e.g. mos.cache.lang.el) is a pre-filtered list of .mo paths for
# one language code, written alongside the main cache on every cache-mode=write
# run. Lookup can then pick from per-language indexes without scanning the full
# master cache.
#

# Normalise language codes: replace hyphens with underscores
_norm_lang() { printf '%s' "$1" | sed 's/-/_/g'; }
_lang_index_file() { printf '%s/mos.cache.lang.%s' "$1" "$2"; }

#
# Build per-language index files from the main cache (called after cache write).
# One awk pass groups every path by its locale-directory component, then writes
# one index file per discovered language code.
#
_build_lang_indexes() {
  local cache_file="$1" cache_dir="$2" locale_dirs="$3" skip_filter="$4"
  [ "$DEBUG" -eq 1 ] && echo "DEBUG: building per-language index files" >&2
  # Remove stale per-language index artifacts before rebuilding.
  local f
  for f in "$cache_dir"/mos.cache.lang.*; do
    [ -e "$f" ] || continue
    rm -f -- "$f"
  done

  awk -v locale_dirs="$locale_dirs" -v skip_filter="$skip_filter" -v outdir="$cache_dir" '
    BEGIN { nd = split(locale_dirs, roots, ":") }
    {
      f = $0
      if (!skip_filter) {
        ok = 0
        for (i=1; i<=nd; i++) {
          if (roots[i] != "" && index(f, roots[i] "/") == 1) { ok=1; break }
        }
        if (!ok) next
      }
      if (match(f, /\/LC_MESSAGES\//)) {
        left = substr(f, 1, RSTART-1)
        n = split(left, parts, "/"); lang = parts[n]
      } else {
        n = split(f, parts, "/"); lang = parts[n-1]
      }
      gsub(/-/, "_", lang)
      sub(/[.@].*/, "", lang)
      gsub(/[^[:alnum:]_]/, "", lang)
      if (lang == "") next
      idx = outdir "/mos.cache.lang." lang
      key = idx SUBSEP f
      if (!seen[key]++) {
        print f >> idx
        count[idx]++
      }
    }
    END {
      for (idx in count) {
        cfile = idx ".count"
        print count[idx] > cfile
        close(cfile)
        close(idx)
      }
    }
  ' "$cache_file"

  if [ "$DEBUG" -eq 1 ]; then
    for f in "$cache_dir"/mos.cache.lang.*; do
      [ -f "$f" ] || continue
      case "$f" in
        *.count) continue ;;
      esac
      echo "DEBUG: index $(wc -l <"$f" | tr -d ' ') entries → $f" >&2
    done
  fi
}

# Build or load cache according to rebuild decision
if [ "$rebuild_cache" -eq 1 ]; then
  TMP_CACHE="$(mktemp -t mos.cache.XXXXXX 2>/dev/null || mktemp)"
  _CLEANUP_TMP_CACHE="$TMP_CACHE"
  trap 'rm -f "${_CLEANUP_TMP_CACHE:-}" "${_CLEANUP_TMP_MATCH:-}"' EXIT

  discover_mo_list "$STRATEGY" "$TMP_CACHE" "$DEBUG" "$ROOTS"

  if [ "$CACHE_MODE" = "write" ]; then
    mkdir -p "$(dirname "${CACHE_FILE}")" 2>/dev/null || true
    mv "$TMP_CACHE" "$CACHE_FILE"
    [ "$DEBUG" -eq 1 ] && echo "DEBUG: cache written with $(wc -l <"${CACHE_FILE}" | tr -d ' ') entries" >&2
    _build_lang_indexes "$CACHE_FILE" "$(dirname "$CACHE_FILE")" "$LOCALE_DIRS" "$SKIP_LOCALE_FILTER"
  else
    # transient list for this run
    CACHE_FILE="$TMP_CACHE"
    [ "$DEBUG" -eq 1 ] && echo "DEBUG: transient list built with $(wc -l <"$CACHE_FILE" | tr -d ' ') entries (not persisted)" >&2
  fi

else
  # Only reached for cache-mode read/write when rebuild not required
  [ "$DEBUG" -eq 1 ] && echo "DEBUG: using existing cache file: ${CACHE_FILE:-} (mode=$CACHE_MODE)" >&2
fi

# Ensure cache file exists and has entries
if [ ! -s "${CACHE_FILE:-}" ]; then
  # Only call it "cache empty" when we actually consulted a persistent cache (cache-mode read/write and not transient).
  if [ "$CACHE_MODE" = "read" ] || [ "$CACHE_MODE" = "write" ]; then
    echo >&2
    echo "No .mo files found (cache empty)." >&2
    echo >&2
    echo "Hint: you asked to use the cache; the cache exists but contains no entries." >&2
    echo >&2
    echo "To build a cache of installed .mo files, run:" >&2
    echo "  ./random-translation --strategy indexed --cache-mode write --refresh LANG" >&2
    echo "or, for a full scan (slower):" >&2
    echo "  ./random-translation --strategy deep --cache-mode write --refresh LANG" >&2
    echo >&2
    echo "Why: the cache is authoritative for fast runs, but cache rebuild strategy still matters when" >&2
    echo "discovering translation files. Using 'indexed' (mdfind/locate) or" >&2
    echo "'deep' (full scan) and writing the results to the cache ensures subsequent runs are fast." >&2
  else
    # cache-mode none (transient discovery) — explain explicit no-cache discovery and suggest building a cache
    echo >&2
    echo "No .mo files found." >&2
    echo >&2
    echo "Note: explicit no-cache mode defaults to the 'quick' discovery strategy, which may not find" >&2
    echo "installed .mo files on some systems. To build a persistent cache that covers more locations," >&2
    echo "run one of the following (replace LANG with your language codes):" >&2
    echo "  ./random-translation --strategy indexed --cache-mode write --refresh LANG" >&2
    echo "  ./random-translation --strategy deep --cache-mode write --refresh LANG" >&2
    echo >&2
    echo "After building the cache you can run without --refresh for faster selection." >&2
  fi
  exit 3
fi

if [ "${CACHE_INIT:-0}" -eq 1 ]; then
  _print_cache_stats
  exit 0
fi

# Normalise requested languages
NORMALS=""
for l in $LANGS; do
  NORMALS="${NORMALS} $(_norm_lang "$l")"
done
NORMALS="${NORMALS# }"

TMP_MATCH="$(mktemp -t mos.match.XXXXXX 2>/dev/null || mktemp)"
_CLEANUP_TMP_MATCH="$TMP_MATCH"
trap 'rm -f "${_CLEANUP_TMP_CACHE:-}" "${_CLEANUP_TMP_MATCH:-}"' EXIT

#
# Fast path: when per-language indexes exist, pick a file using weighted counts
# and choose a random entry from that file. This avoids full-cache scans.
#
_use_fast_path=0
if [ "$CACHE_MODE" != "none" ]; then
  _all_indexed=1
  _total_count=0
  _weighted=""
  for lang in $NORMALS; do
    _base="${lang%%_*}"
    idx="$(_lang_index_file "$CACHE_DIR" "$lang")"
    idx_base="$(_lang_index_file "$CACHE_DIR" "$_base")"
    if [ -s "$idx" ]; then
      cfile="${idx}.count"
      c=0
      [ -s "$cfile" ] && c=$(tr -d '[:space:]' <"$cfile" 2>/dev/null || echo 0)
      case "$c" in
        ''|*[!0-9]*) c=0 ;;
      esac
      [ "$c" -eq 0 ] && c=$(wc -l <"$idx" | tr -d ' ')
      _weighted="${_weighted}${idx}"$'\t'"${c}"$'\n'
      _total_count=$((_total_count + c))
    elif [ "$lang" != "$_base" ] && [ -s "$idx_base" ]; then
      cfile="${idx_base}.count"
      c=0
      [ -s "$cfile" ] && c=$(tr -d '[:space:]' <"$cfile" 2>/dev/null || echo 0)
      case "$c" in
        ''|*[!0-9]*) c=0 ;;
      esac
      [ "$c" -eq 0 ] && c=$(wc -l <"$idx_base" | tr -d ' ')
      _weighted="${_weighted}${idx_base}"$'\t'"${c}"$'\n'
      _total_count=$((_total_count + c))
    else
      _all_indexed=0; break
    fi
  done
  if [ "$_all_indexed" -eq 1 ] && [ "$_total_count" -gt 0 ]; then
    pick=$(
      awk -v total="$_total_count" '
        BEGIN {
          srand()
          r = int(rand() * total) + 1
          acc = 0
        }
        NF >= 2 {
          path = $1
          c = $2 + 0
          if (c <= 0) next
          acc += c
          if (acc >= r) { print path; exit }
        }
      ' <<<"$_weighted"
    )
    if [ -n "$pick" ] && [ -s "$pick" ]; then
      lines=$(wc -l <"$pick" | tr -d ' ')
      if [ "$lines" -gt 0 ]; then
        line_pick=$(awk -v total="$lines" 'BEGIN { srand(); print int(rand() * total) + 1 }')
        selected=$(awk -v want="$line_pick" 'NR==want{print; exit}' "$pick")
      fi
    fi
  fi
  if [ -n "${selected:-}" ]; then
    _use_fast_path=1
    [ "$DEBUG" -eq 1 ] && echo "DEBUG: fast path via language index files (weighted random)" >&2
  else
    [ "$DEBUG" -eq 1 ] && echo "DEBUG: index unavailable/incomplete, falling back to awk scan" >&2
  fi
fi

#
# Standard path: single awk pass over the master cache.
# Used for all strategies other than cached, or when indexes are absent.
#
if [ "$_use_fast_path" -eq 0 ]; then
  awk -v langs="$NORMALS" -v locale_dirs="$LOCALE_DIRS" -v skip_filter="$SKIP_LOCALE_FILTER" '
    BEGIN {
      nd = split(locale_dirs, roots, ":")
      nl = split(langs, wanted, " ")
    }
    {
      f = $0
      if (!skip_filter) {
        ok = 0
        for (i=1; i<=nd; i++) {
          if (roots[i] != "" && index(f, roots[i] "/") == 1) { ok=1; break }
        }
        if (!ok) next
      }
      if (match(f, /\/LC_MESSAGES\//)) {
        left = substr(f, 1, RSTART-1)
        n = split(left, parts, "/"); lcnorm = parts[n]
      } else {
        n = split(f, parts, "/"); lcnorm = parts[n-1]
      }
      gsub(/-/, "_", lcnorm)
      for (i=1; i<=nl; i++) {
        w = wanted[i]
        if (lcnorm == w \
            || index(lcnorm, w "_") == 1 \
            || index(lcnorm, w ".") == 1 \
            || index(lcnorm, w "-") == 1 \
            || (index(lcnorm, w) == 1 && length(lcnorm) > length(w))) {
          if (!seen[f]++) print f
          break
        }
      }
    }
  ' "${CACHE_FILE}" > "$TMP_MATCH"
fi

if [ "$_use_fast_path" -eq 0 ] && [ ! -s "$TMP_MATCH" ]; then
  [ "$DEBUG" -eq 1 ] && { echo "DEBUG: cache sample (first 50):" >&2; head -n 50 "${CACHE_FILE}" >&2 || true; }
  echo "No .mo files found for languages: $LANGS" >&2
  exit 3
fi

if [ "$_use_fast_path" -eq 0 ]; then
  count=$(wc -l <"$TMP_MATCH" | tr -d ' ')
  [ "$DEBUG" -eq 1 ] && echo "DEBUG: matched $count .mo files for languages: $LANGS" >&2
  selected=$(awk 'BEGIN{srand()} {a[NR]=$0} END{if(NR>0) print a[int(rand()*NR)+1]}' "$TMP_MATCH" || true)
fi
if [ -z "$selected" ]; then
  [ "$DEBUG" -eq 1 ] && echo "DEBUG: no selection possible" >&2
  echo "No .mo file would be selected for languages: $LANGS" >&2
  exit 3
fi
[ "$DEBUG" -eq 1 ] && printf 'DEBUG: Selected: %s\n' "$selected" >&2

_want_color() {
  case "${COLOR_MODE:-auto}" in
    always) return 0 ;;
    never)  return 1 ;;
    auto)
      [ -n "${NO_COLOR:-}" ] && return 1
      [ -t 1 ]
      return
      ;;
  esac
  return 1
}

_emit_json() {
  local payload="$1"
  if _want_color && command -v jq >/dev/null 2>&1; then
    printf '%s\n' "$payload" | jq -C .
  else
    printf '%s\n' "$payload"
  fi
}

_emit_yaml() {
  local payload="$1"
  if _want_color; then
    local esc
    esc="$(printf '\033')"
    printf '%s\n' "$payload" | awk -v esc="$esc" '
      {
        line = $0
        if (line ~ /^[[:space:]]*header:$/ || line ~ /^[[:space:]]*translations:$/) {
          print esc "[1;36m" line esc "[0m"; next
        }
        if (line ~ /^[[:space:]]*-[[:space:]]+msgid:[[:space:]]*\|[[:space:]]*$/) {
          print esc "[1;33m" line esc "[0m"; next
        }
        if (line ~ /^[[:space:]]*msgstr:[[:space:]]*\|[[:space:]]*$/) {
          print esc "[1;32m" line esc "[0m"; next
        }
        if (line ~ /^[[:space:]]*"[^"]+":/) {
          print esc "[0;34m" line esc "[0m"; next
        }
        print line
      }
    '
  else
    printf '%s\n' "$payload"
  fi
}

_format_normal_po() {
  local esc use_color
  use_color=0
  if _want_color; then
    use_color=1
    esc="$(printf '\033')"
  else
    esc=""
  fi

  awk -v include_header="$INCLUDE_HEADER" -v include_meta="$INCLUDE_META" -v color="$use_color" -v esc="$esc" '
    BEGIN { RS=""; ORS="\n\n" }
    /^msgid ""/ {
      if (!include_header) next
    }
    {
      n = split($0, lines, "\n")
      out = ""
      for (i = 1; i <= n; i++) {
        line = lines[i]
        if (line ~ /^#/) {
          # Strip noisy PO comments by default; metadata of interest is msgctxt.
          continue
        }
        if (line ~ /^msgctxt / && !include_meta) {
          continue
        }

        if (color) {
          if (line ~ /^msgctxt /) {
            line = esc "[1;36mmsgctxt" esc "[0m" substr(line, 8)
          } else if (line ~ /^msgid_plural /) {
            line = esc "[1;35mmsgid_plural" esc "[0m" substr(line, 13)
          } else if (line ~ /^msgid /) {
            line = esc "[1;33mmsgid" esc "[0m" substr(line, 6)
          } else if (line ~ /^msgstr\[[0-9]+\] /) {
            p = index(line, " ")
            token = substr(line, 1, p - 1)
            rest = substr(line, p)
            line = esc "[1;32m" token esc "[0m" rest
          } else if (line ~ /^msgstr /) {
            line = esc "[1;32mmsgstr" esc "[0m" substr(line, 7)
          }
        }

        if (length(out) > 0) out = out "\n"
        out = out line
      }
      if (length(out) > 0) print out
    }
  '
}

# If output mode is filename (or dry-run), print the filename and exit
if [ "$OUTPUT_MODE" = "filename" ]; then
  # Print to stdout for pipeline consumption
  printf '%s\n' "$selected"
  exit 0
fi

# Extraction helpers
#
# On macOS, /usr/bin/python3 is an Xcode Command Line Tools stub that invokes
# xcrun, which is blocked inside the App Sandbox (Phosphor / XScreenSaver on
# macOS Sequoia).  Prefer real interpreter binaries from known package manager
# and framework paths over the stub.  Fall back to the stub only as a last
# resort (it works fine outside a sandbox, e.g. in a terminal).
#
_find_real_python() {
  local candidates=(
    /opt/homebrew/bin/python3
    /usr/local/bin/python3
    /opt/local/bin/python3
    /usr/bin/python3
    /usr/local/bin/python
    /usr/bin/python
  )
  # Also sweep Python.framework versioned binaries (macOS system or user installs)
  for fw in \
      /Library/Frameworks/Python.framework/Versions/Current/bin/python3 \
      /System/Library/Frameworks/Python.framework/Versions/Current/bin/python3; do
    [ -x "$fw" ] && candidates+=("$fw")
  done
  local py
  for py in "${candidates[@]}"; do
    [ -x "$py" ] || continue
    # Skip Xcode stubs: they are tiny shell wrappers that exec xcrun
    case "$(head -c 512 "$py" 2>/dev/null)" in
      *xcrun*) continue ;;
    esac
    printf '%s' "$py"
    return 0
  done
  return 1
}

PY=$(_find_real_python 2>/dev/null || true)
[ "$DEBUG" -eq 1 ] && printf 'DEBUG: resolved python=%s\n' "${PY:-(none)}" >&2
HAS_MSGUNFMT=0
if command -v msgunfmt >/dev/null 2>&1; then HAS_MSGUNFMT=1; fi

# Helper: use Python to load .mo and return catalog as list of (msgid,msgstr)
# Use python reading script from stdin and pass selected path as argv[1] (python - selected <<'PY')
if [ "$OUTPUT_MODE" = "json" ] || [ "$OUTPUT_MODE" = "yaml" ] || [ "$N_STRINGS" -gt 0 ]; then
  if [ -n "$PY" ]; then
    if [ "$OUTPUT_MODE" = "json" ]; then
      json_payload="$("$PY" - "$selected" "$N_STRINGS" "$INCLUDE_HEADER" <<'PYCODE'
import sys, json, random
from gettext import GNUTranslations
p = sys.argv[1]
n = int(sys.argv[2]) if len(sys.argv) > 2 else 0
include_header = int(sys.argv[3]) if len(sys.argv) > 3 else 0
try:
    with open(p,'rb') as fh:
        t = GNUTranslations(fh)
except Exception as e:
    print(json.dumps({"error":str(e)}))
    sys.exit(1)
cat = getattr(t,'_catalog',{}) or {}
header = {}
raw_header = cat.get('', '')
if isinstance(raw_header, str):
    for line in raw_header.splitlines():
        if ':' not in line:
            continue
        k, v = line.split(':', 1)
        k = k.strip()
        if k:
            header[k] = v.strip()
out=[]
for k,v in cat.items():
    if k == '':
        continue
    # Plural forms: if k is a tuple, pick one at random so output varies across runs.
    if isinstance(k,tuple):
        k = random.choice(k)
    out.append({"msgid":k,"msgstr":v})
if n > 0:
    random.shuffle(out)
    out = out[:n]
if include_header:
    print(json.dumps({"header": header, "translations": out}, ensure_ascii=False))
else:
    print(json.dumps(out, ensure_ascii=False))
PYCODE
)"
      _emit_json "$json_payload"
      exit 0
    fi

    if [ "$OUTPUT_MODE" = "yaml" ]; then
      # Python YAML emitter: preserve Unicode, replace tabs with two spaces, sanitize control chars
      yaml_payload="$("$PY" - "$selected" "$N_STRINGS" "$INCLUDE_HEADER" <<'PYCODE'
import sys, re, random
from gettext import GNUTranslations
p = sys.argv[1]
n = int(sys.argv[2]) if len(sys.argv) > 2 else 0
include_header = int(sys.argv[3]) if len(sys.argv) > 3 else 0
try:
    with open(p,'rb') as fh:
        t = GNUTranslations(fh)
except Exception as e:
    sys.stderr.write("error: %s\n" % e)
    sys.exit(1)
cat = getattr(t,'_catalog',{}) or {}

def safe_lines(s):
    if s is None:
        return ['']
    text = str(s)
    # replace tabs with 2 spaces
    text = text.replace('\t', '  ')
    # replace control characters except newline (0x0A) and carriage return (0x0D) with '?'
    text = re.sub(r'[\x00-\x09\x0b\x0c\x0e-\x1f]', '?', text)
    # split into lines (preserve empty lines)
    lines = text.splitlines() or ['']
    return lines

def yaml_key(s):
    return '"' + str(s).replace('\\', '\\\\').replace('"', '\\"') + '"'

header = {}
raw_header = cat.get('', '')
if isinstance(raw_header, str):
    for line in raw_header.splitlines():
        if ':' not in line:
            continue
        k, v = line.split(':', 1)
        k = k.strip()
        if k:
            header[k] = v.strip()

items = [(k,v) for k,v in cat.items() if k != '']
if n > 0:
    random.shuffle(items)
    items = items[:n]

if include_header:
    print("header:")
    if header:
        for hk in sorted(header.keys()):
            print("  " + yaml_key(hk) + ": |")
            for line in safe_lines(header[hk]):
                print("    " + line)
    else:
        print("  {}")
    print("translations:")
for k,v in items:
    # Plural forms: if k is a tuple, pick one at random so output varies across runs.
    if isinstance(k,tuple):
        k = random.choice(k)
    prefix = "  " if include_header else ""
    print(prefix + "- msgid: |")
    for line in safe_lines(k):
        print(prefix + "    " + line)
    print(prefix + "  msgstr: |")
    for line in safe_lines(v):
        print(prefix + "    " + line)
PYCODE
)"
      _emit_yaml "$yaml_payload"
      exit 0
    fi

    if [ "$N_STRINGS" -gt 0 ]; then
      "$PY" - "$selected" "$N_STRINGS" <<'PYCODE' | _format_normal_po
import sys, random
from gettext import GNUTranslations
p = sys.argv[1]
n = int(sys.argv[2])
try:
    with open(p,'rb') as fh:
        t = GNUTranslations(fh)
except Exception as e:
    sys.stderr.write("python: failed to read .mo: %s\n" % e)
    sys.exit(1)
cat = getattr(t,'_catalog',{}) or {}
pairs = []
seen = set()
for k,v in cat.items():
    if k == '' or not v:
        continue
    if isinstance(k,tuple):
        k = random.choice(k)
    if k not in seen:
        seen.add(k)
        pairs.append((k,v))
if not pairs:
    sys.exit(0)
random.shuffle(pairs)
for k,v in pairs[:n]:
    import json
    print('msgid ' + json.dumps(k, ensure_ascii=False))
    print('msgstr ' + json.dumps(v, ensure_ascii=False))
    print()
PYCODE
      exit 0
    fi

  else
    # No python: fall back to msgunfmt for -n or json/yaml best-effort
    if [ "$HAS_MSGUNFMT" -eq 1 ]; then
      if [ "$OUTPUT_MODE" = "json" ]; then
        # best-effort: parse msgunfmt output into JSON
        json_payload="$(msgunfmt "$selected" | awk '
          BEGIN{RS=""; ORS=""; print "["}
          {
            id=""; str="";
            for(i=1;i<=NF;i++){
              if($i ~ /^msgid /){sub(/^msgid /,"",$i); id=$i}
              if($i ~ /^msgstr /){sub(/^msgstr /,"",$i); str=$i}
            }
            if(id!="" || str!=""){
              gsub(/^"/,"",id); gsub(/"$/,"",id);
              gsub(/^"/,"",str); gsub(/"$/,"",str);
              if(NR>1) printf(",")
              printf("{\"msgid\":\"%s\",\"msgstr\":\"%s\"}", id, str)
            }
          }
          END{print "]"}')"
        _emit_json "$json_payload"
        exit 0
      fi

      if [ "$OUTPUT_MODE" = "yaml" ]; then
        # Prefer perl if available; otherwise use tr+awk fallback.
        if command -v perl >/dev/null 2>&1; then
          yaml_payload="$(msgunfmt "$selected" | \
            perl -CSD -pe 's/\t/  /g; s/[\x00-\x09\x0b\x0c\x0e-\x1f]/?/g' | \
            awk '
              BEGIN{RS=""; ORS=""}
              {
                id=""; str="";
                for(i=1;i<=NF;i++){
                  if($i ~ /^msgid /){sub(/^msgid /,"",$i); id=$i}
                  if($i ~ /^msgstr /){sub(/^msgstr /,"",$i); str=$i}
                }
                if(id!="" || str!=""){
                  gsub(/^"/,"",id); gsub(/"$/,"",id);
                  gsub(/^"/,"",str); gsub(/"$/,"",str);
                  print "- msgid: |\n"
                  n=split(id,lines,"\n")
                  for(i=1;i<=n;i++) printf("    %s\n", lines[i])
                  print "  msgstr: |\n"
                  n=split(str,lines2,"\n")
                  for(i=1;i<=n;i++) printf("    %s\n", lines2[i])
                }
              }')"
        else
          # Portable fallback: tr replaces tabs with two spaces and control bytes with '?'
          yaml_payload="$(msgunfmt "$selected" | \
            tr '\t' '  ' | \
            tr '\001-\011\013\014\016-\037' '?' | \
            awk '
              BEGIN{RS=""; ORS=""}
              {
                id=""; str="";
                for(i=1;i<=NF;i++){
                  if($i ~ /^msgid /){sub(/^msgid /,"",$i); id=$i}
                  if($i ~ /^msgstr /){sub(/^msgstr /,"",$i); str=$i}
                }
                if(id!="" || str!=""){
                  gsub(/^"/,"",id); gsub(/"$/,"",id);
                  gsub(/^"/,"",str); gsub(/"$/,"",str);
                  print "- msgid: |\n"
                  n=split(id,lines,"\n")
                  for(i=1;i<=n;i++) printf("    %s\n", lines[i])
                  print "  msgstr: |\n"
                  n=split(str,lines2,"\n")
                  for(i=1;i<=n;i++) printf("    %s\n", lines2[i])
                }
              }')"
        fi
        _emit_yaml "$yaml_payload"
        exit 0
      fi

      if [ "$N_STRINGS" -gt 0 ]; then
        # Collect each msgid/msgstr paragraph from msgunfmt output, skip the
        # PO header (empty msgid), pick N at random, and print them.
        msgunfmt "$selected" | awk -v n="$N_STRINGS" '
          BEGIN { RS=""; ORS="" }
          # Skip the header entry (msgid "")
          /^msgid ""/ { next }
          { records[NR] = $0 }
          END {
            srand()
            total = length(records)
            printed = 0
            while (printed < n && total > 0) {
              # pick a random remaining key
              target = int(rand() * total) + 1
              i = 0
              for (k in records) {
                i++
                if (i == target) {
                  print records[k] "
"
                  delete records[k]
                  total--
                  printed++
                  break
                }
              }
            }
          }
        ' | _format_normal_po
        exit 0
      fi
    else
      # Neither python nor msgunfmt: -n N can still use the od/awk fallback
      # (defined below).  JSON/YAML require one of the above tools.
      if [ "$N_STRINGS" -le 0 ]; then
        echo "error: JSON/YAML output requires python or msgunfmt." >&2
        exit 2
      fi
      # fall through — _mo_extract_n_awk will be called after its definition
    fi
  fi
fi

# Last-resort fallback for -n N: extract msgid/msgstr pairs from the .mo binary
# using only od and awk (no Python, no msgunfmt required).
#
# GNU .mo format (little-endian magic 0x950412de):
#   offset 8:  number of strings (N)
#   offset 12: offset of original-string table (each entry: length u32 + offset u32)
#   offset 16: offset of translated-string table (same layout)
#
# This is intentionally best-effort: non-printable bytes and control chars are
# stripped; empty entries and the header (msgid="") are skipped.
#
_mo_extract_n_awk() {
  local mo="$1" n="$2"
  if ! command -v od >/dev/null 2>&1; then
    return 1
  fi

  # Verify little-endian magic (0x950412de = 3725722334 decimal)
  local magic
  magic=$(od -A n -t u4 -N 4 "$mo" 2>/dev/null | tr -d ' \n')
  [ "$magic" = "3725722334" ] || return 1

  # Read header fields
  local num_strings orig_off trans_off
  num_strings=$(od -A n -t u4 -j 8  -N 4 "$mo" 2>/dev/null | tr -d ' \n')
  orig_off=$(   od -A n -t u4 -j 12 -N 4 "$mo" 2>/dev/null | tr -d ' \n')
  trans_off=$(  od -A n -t u4 -j 16 -N 4 "$mo" 2>/dev/null | tr -d ' \n')
  [ "${num_strings:-0}" -gt 0 ] || return 1

  # Collect msgid/msgstr pairs into a temp file, one pair per two lines
  local tmp
  tmp="$(mktemp -t mo_pairs.XXXXXX 2>/dev/null || mktemp)"

  _extract_str() {
    dd if="$mo" bs=1 skip="$1" count="$2" 2>/dev/null       | tr '\000' '\n'       | head -1       | tr -d '\001-\010\013\014\016-\037'
  }

  local i orig_len orig_pos str_len str_pos msgid msgstr
  for i in $(seq 0 $((num_strings - 1))); do
    orig_len=$(od -A n -t u4 -j $((orig_off  + i * 8))     -N 4 "$mo" 2>/dev/null | tr -d ' \n')
    orig_pos=$(od -A n -t u4 -j $((orig_off  + i * 8 + 4)) -N 4 "$mo" 2>/dev/null | tr -d ' \n')
    str_len=$( od -A n -t u4 -j $((trans_off + i * 8))     -N 4 "$mo" 2>/dev/null | tr -d ' \n')
    str_pos=$( od -A n -t u4 -j $((trans_off + i * 8 + 4)) -N 4 "$mo" 2>/dev/null | tr -d ' \n')
    # skip header (empty msgid) and empty translations
    [ "${orig_len:-0}" -gt 0 ] || continue
    [ "${str_len:-0}"  -gt 0 ] || continue
    msgid=$(  _extract_str "$orig_pos" "$orig_len")
    msgstr=$( _extract_str "$str_pos"  "$str_len")
    [ -n "$msgid" ] && [ -n "$msgstr" ] || continue
    printf '%s\t%s\n' "$msgid" "$msgstr" >> "$tmp"
  done

  # Deduplicate by msgid, shuffle, pick n, and print as msgid/msgstr pairs
  awk -v n="$n" '
    !seen[$1]++ { a[NR]=$0 }
    END {
      srand()
      for (i=1; i<=n && i<=NR; i++) {
        idx = int(rand()*NR)+1
        split(a[idx], p, "\t")
        print "msgid "  p[1]
        print "msgstr " p[2]
        print ""
      }
    }
  ' "$tmp"
  rm -f "$tmp"
  return 0
}

# Invoke the od/awk fallback if we reached here with N_STRINGS > 0
# (means neither python nor msgunfmt handled it above)
if [ "${N_STRINGS:-0}" -gt 0 ]; then
  [ "$DEBUG" -eq 1 ] && echo "DEBUG: using od/awk .mo fallback extractor" >&2
  tmp_fallback="$(mktemp -t mo_extract.XXXXXX 2>/dev/null || mktemp)"
  if _mo_extract_n_awk "$selected" "$N_STRINGS" >"$tmp_fallback"; then
    cat "$tmp_fallback" | _format_normal_po
    rm -f "$tmp_fallback"
    exit 0
  else
    rm -f "$tmp_fallback"
    echo "error: .mo extraction failed; no python, msgunfmt, or od available." >&2
    exit 2
  fi
fi

# Default: print PO-like output (normal mode)
if [ "$OUTPUT_MODE" = "normal" ]; then
  if [ "$HAS_MSGUNFMT" -eq 1 ]; then
    msgunfmt "$selected" | _format_normal_po
    exit 0
  else
    if [ -n "$PY" ]; then
      "$PY" - "$selected" "$INCLUDE_HEADER" "$INCLUDE_META" "$(_want_color && echo 1 || echo 0)" <<'PYCODE'
import sys, random
from gettext import GNUTranslations
p = sys.argv[1]
include_header = int(sys.argv[2]) if len(sys.argv) > 2 else 0
include_meta = int(sys.argv[3]) if len(sys.argv) > 3 else 0
use_color = int(sys.argv[4]) if len(sys.argv) > 4 else 0
Y = "\033[1;33m"; G = "\033[1;32m"; C = "\033[1;36m"; R = "\033[0m"
def c(tok, col):
    if not use_color:
        return tok
    return col + tok + R
try:
    with open(p,'rb') as fh:
        t = GNUTranslations(fh)
except Exception as e:
    sys.stderr.write("python: failed to read .mo: %s\n" % e)
    sys.exit(1)
cat = getattr(t,'_catalog',{}) or {}
for k,v in cat.items():
    if k == '':
        if include_header:
            print(c("msgid", Y) + ' ""')
            print(c("msgstr", G) + ' ""')
            for line in str(v).splitlines():
                print(line)
            print()
        continue
    if not v:
        continue
    ctxt = None
    if isinstance(k, str) and "\x04" in k:
        ctxt, k = k.split("\x04", 1)
    if ctxt and include_meta:
        print(c("msgctxt", C) + ' "%s"' % ctxt)
    # Plural forms note: if k is a tuple (plural forms), pick one at random so output varies across runs.
    if isinstance(k,tuple):
        k = random.choice(k)
    print(c("msgid", Y) + ' "%s"' % (k,))
    print(c("msgstr", G) + ' "%s"' % (v,))
    print()
PYCODE
      exit 0
    else
      echo "error: neither msgunfmt nor python available to show translations." >&2
      exit 2
    fi
  fi
fi

# Should not reach here
exit 0
