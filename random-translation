              if      (_hc >= "0" && _hc <= "9") _hd = _hc + 0
              else if (_hc >= "a" && _hc <= "f") _hd = _hc=="a"?10:_hc=="b"?11:_hc=="c"?12:_hc=="d"?13:_hc=="e"?14:15
              else if (_hc >= "A" && _hc <= "F") _hd = _hc=="A"?10:_hc=="B"?11:_hc=="C"?12:_hc=="D"?13:_hc=="E"?14:15
              else _hd = 0
              hv = hv * 16 + _hd
            }
            o = o sprintf("%c", hv); i += 6
          }
          else { o = o n; i += 2 }
        } else { o = o c; i++ }
      }
      return o
    }
    # JSON-escape a plain string (backslash first, then double-quote)
    function jesc(s) { gsub(/\\/, "\\\\", s); gsub(/"/, "\\\"", s); return s }
    BEGIN { total = 0; hdr_ri = ""; hdr_rs = "" }
    {
      tab = index($0, "\t")
      if (tab == 0) { lines[++total] = $0; next }
      ri = substr($0, 1, tab-1)
      if (ri == "\"\"" && inc_meta) { hdr_ri = ri; hdr_rs = substr($0, tab+1); next }
      lines[++total] = $0
    }
    END {
      srand()
      # partial Fisher-Yates to pick n_want indices without replacement
      for (i = 1; i <= total; i++) idx[i] = i
      out = (n_want > 0 && n_want < total) ? n_want : total
      for (i = 1; i <= out; i++) {
        j = i + int(rand() * (total - i + 1))
        tmp2 = idx[i]; idx[i] = idx[j]; idx[j] = tmp2
      }

      n_total = (hdr_ri != "" ? 1 : 0) + out
      n_printed = 0

      print br "[" cr

      if (hdr_ri != "") {
        n_printed++
        comma = (n_printed < n_total) ? (br "," cr) : ""
        # Decode the raw header msgstr and parse Key: Value lines into a dict
        hdr_raw = junesc(substr(hdr_rs, 2, length(hdr_rs)-2))
        n_hlines = split(hdr_raw, _hlines, "\n")
        printf "  %s{%s\n",                        br, cr
        printf "    %s\"header\"%s %s{%s\n",        jk, br ":" cr, br, cr
        first_field = 1
        for (_hi = 1; _hi <= n_hlines; _hi++) {
          _col = index(_hlines[_hi], ": ")
          if (_col == 0) continue
          _hk = jesc(substr(_hlines[_hi], 1, _col-1))
          _hv = jesc(substr(_hlines[_hi], _col+2))
          sub(/\\n$/, "", _hv)
          if (!first_field) printf ",\n"
          printf "      %s\"%s\"%s %s\"%s\"%s", jk, _hk, br ":" cr, jv, _hv, cr
          first_field = 0
        }
        if (!first_field) printf "\n"
        printf "    %s}%s\n",  br, cr
        printf "  %s}%s\n",    br, comma cr
      }

      for (i = 1; i <= out; i++) {
        ln  = lines[idx[i]]
        tab = index(ln, "\t")
        if (tab == 0) continue
        n_printed++
        ri = substr(ln, 1, tab-1)
        rs = substr(ln, tab+1)
        comma = (n_printed < n_total) ? (br "," cr) : ""
        printf "  %s{%s\n",                   br, cr
        printf "    %s\"msgid\"%s %s%s%s,\n", jk, br ":" cr, jv, ri, cr
        printf "    %s\"msgstr\"%s %s%s%s\n", jk, br ":" cr, jv, rs, cr
        printf "  %s}%s\n",                   br, comma cr
      }
      print br "]" cr
    }
  ' "$tmp"
  rm -f "$tmp"
}

#
# Read tab-separated JSON pairs from stdin, emit YAML block scalars.
# N_WANT=0 means emit all entries.
#
_fmt_yaml() {
  local n_want="$1"
  local tmp
  tmp=$(mktemp -t rt_yaml.XXXXXX 2>/dev/null || mktemp)
  cat > "$tmp"
  awk \
    -v n_want="$n_want" \
    -v inc_meta="$INCLUDE_META" \
    -v br="$C_J_BR" \
    -v jk="$C_J_KY" \
    -v jv="$C_J_SV" \
    -v cr="$C_RST" \
    '
    function junesc(s,    o, i, c, n) {
      o = ""; i = 1
      while (i <= length(s)) {
        c = substr(s, i, 1)
        if (c == "\\") {
          n = substr(s, i+1, 1)
          if      (n == "n")  { o = o "\n"; i += 2 }
          else if (n == "t")  { o = o "  "; i += 2 }
          else if (n == "\\") { o = o "\\"; i += 2 }
          else if (n == "\"") { o = o "\""; i += 2 }
          else                { o = o n;    i += 2 }
        } else { o = o c; i++ }
      }
      return o
    }

    # emit a block-scalar value indented by `pad` spaces, optionally colored
    function yaml_block(val, pad, col, rst,    lns, n, i) {
      n = split(val, lns, "\n")
      for (i = 1; i <= n; i++) printf "%s%s%s%s\n", pad, col, lns[i], rst
    }

    BEGIN { total = 0; hdr_ri = ""; hdr_rs = "" }
    {
      tab = index($0, "\t")
      if (tab == 0) { lines[++total] = $0; next }
      ri = substr($0, 1, tab-1)
      if (ri == "\"\"" && inc_meta) { hdr_ri = ri; hdr_rs = substr($0, tab+1); next }
      lines[++total] = $0
    }
    END {
      srand()
      for (i = 1; i <= total; i++) idx[i] = i
      out = (n_want > 0 && n_want < total) ? n_want : total
      for (i = 1; i <= out; i++) {
        j = i + int(rand() * (total - i + 1))
        tmp2 = idx[i]; idx[i] = idx[j]; idx[j] = tmp2
      }
      if (hdr_ri != "") {
        # Parse header msgstr into Key: Value fields
        hdr_raw = junesc(substr(hdr_rs, 2, length(hdr_rs)-2))
        n_hlines = split(hdr_raw, _hlines, "\n")
        printf "%s- header:%s\n", jk, cr
        for (_hi = 1; _hi <= n_hlines; _hi++) {
          _col = index(_hlines[_hi], ": ")
          if (_col == 0) continue
          _hk = substr(_hlines[_hi], 1, _col-1)
          _hv = substr(_hlines[_hi], _col+2)
          sub(/\\n$/, "", _hv)
          # Quote value if it contains YAML-special characters
          if (_hv ~ /[:{}\[\],#&*!|>'"'"'"%@`]/ || _hv ~ /^[ \t]/ || _hv == "") {
            gsub(/"/, "\\\"", _hv)
            printf "    %s%s%s: %s\"%s\"%s\n", jk, _hk, cr, jv, _hv, cr
          } else {
            printf "    %s%s%s: %s%s%s\n", jk, _hk, cr, jv, _hv, cr
          }
        }
      }
      for (i = 1; i <= out; i++) {
        ln  = lines[idx[i]]
        tab = index(ln, "\t")
        if (tab == 0) continue
        ri = substr(ln, 1, tab-1)
        rs = substr(ln, tab+1)
        mid = junesc(substr(ri, 2, length(ri)-2))
        mst = junesc(substr(rs, 2, length(rs)-2))
        printf "%s- msgid:%s %s|%s\n",   jk, cr, br, cr
        yaml_block(mid, "    ", jv, cr)
        printf "%s  msgstr:%s %s|%s\n",  jk, cr, br, cr
        yaml_block(mst, "    ", jv, cr)
      }
    }
  ' "$tmp"
  rm -f "$tmp"
}

#
# _mo_read_with_retry FILE [INDEX_FILE]
#
# Calls _mo_read and retries with a different randomly-selected file from the
# same language index if the result is empty. This handles .mo files that exist
# but contain zero translatable strings (stub files, partially installed
# packages, encoding-only catalogs, etc.) without the cost of pre-filtering.
#
# At most 5 retries to prevent infinite loops on degenerate indexes.
#
_mo_read_with_retry() {
  local mo="$1" idx_file="${2:-}" attempt result_file retries=5
  result_file=$(mktemp -t rt_read.XXXXXX 2>/dev/null || mktemp)

  _mo_read "$mo" > "$result_file"

  if [ -s "$result_file" ] || [ -z "$idx_file" ] || [ ! -s "$idx_file" ]; then
    cat "$result_file"
    rm -f "$result_file"
    return
  fi

  # Empty result and we have an index to retry from
  _debug "$mo yielded no pairs, retrying from index"
  local tried="$mo"
  local lines attempt_mo
  lines=$(wc -l <"$idx_file" | tr -d ' ')
  attempt=0
  while [ "$attempt" -lt "$retries" ]; do
    attempt=$((attempt + 1))
    # Pick a random line from the index, skipping already-tried files
    attempt_mo=$(awk -v tried="$tried" -v total="$lines" '
      BEGIN { srand(); count = 0 }
      { if (index(tried, $0) == 0) { a[++count] = $0 } }
      END { if (count > 0) print a[int(rand()*count)+1] }
    ' "$idx_file")
    [ -z "$attempt_mo" ] && break
    _debug "retry $attempt: $attempt_mo"
    tried="${tried}|${attempt_mo}"
    _mo_read "$attempt_mo" > "$result_file"
    if [ -s "$result_file" ]; then
      # Update selected to the working file for accurate --debug output
      selected="$attempt_mo"
      break
    fi
  done

  cat "$result_file"
  rm -f "$result_file"
}

case "$OUTPUT_MODE" in
  json)
    _mo_read_with_retry "$selected" "$_selected_index" | _fmt_json "$N_STRINGS"
    ;;
  yaml)
    _mo_read_with_retry "$selected" "$_selected_index" | _fmt_yaml "$N_STRINGS"
    ;;
  human|raw)
    _fmt_fn="_fmt_raw"
    [ "$OUTPUT_MODE" = "human" ] && _fmt_fn="_fmt_human"
    if [ "$N_STRINGS" -gt 0 ]; then
      _mo_read_with_retry "$selected" "$_selected_index" | awk \
        -v n="$N_STRINGS" -v inc_meta="$INCLUDE_META" '
        BEGIN { total = 0; hdr = "" }
        {
          tab = index($0, "\t")
          if (tab > 0 && substr($0, 1, tab-1) == "\"\"" && inc_meta) {
            hdr = $0; next
          }
          lines[++total] = $0
        }
        END {
          srand()
          for (i = 1; i <= total; i++) idx[i] = i
          out = (n > 0 && n < total) ? n : total
          for (i = 1; i <= out; i++) {
            j = i + int(rand() * (total - i + 1))
            t = idx[i]; idx[i] = idx[j]; idx[j] = t
          }
          if (hdr != "") print hdr
          for (i = 1; i <= out; i++) print lines[idx[i]]
        }
      ' | "$_fmt_fn"
    else
      _mo_read_with_retry "$selected" "$_selected_index" | "$_fmt_fn"
    fi
    ;;
esac

exit 0
