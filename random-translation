  C_J_BR="${COL_BOLD_WHITE}"                # brackets / structural punctuation
  C_J_KY="${COL_256_BOLD_VIOLET}"           # keys
  C_J_SV="${COL_256_SAGE_GREEN}"            # strings

  # human
  C_H_SRC="${COL_256_DIM_VERY_LIGHT_GREY}"  # source
  C_H_TRR="${COL_256_BOLD_SAGE_GREEN}"      # translation
  C_H_ARR="${COL_256_VIOLET}"               # arrow
