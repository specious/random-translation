              else if (_hc >= "A" && _hc <= "F") _hd = _hc=="A"?10:_hc=="B"?11:_hc=="C"?12:_hc=="D"?13:_hc=="E"?14:15
              else _hd = 0
              hv = hv * 16 + _hd
            }
            o = o sprintf("%c", hv); i += 6
          }
          else { o = o n; i += 2 }
        } else { o = o c; i++ }
      }
      return o
    }

    function clean_appname(a,    parts, n, last, first) {
      if (index(a, ".") > 0) {
        n = split(a, parts, ".")
        first = tolower(parts[1])
        if (first == "com" || first == "org" || first == "net" || first == "io" ||
            first == "de"  || first == "fr"  || first == "co"  || first == "uk" ||
            first == "app" || first == "xyz" || first == "dev") {
          last = parts[n]
        } else {
          last = a
        }
      } else {
        last = a
      }
      return toupper(substr(last,1,1)) substr(last,2)
    }

    function locale_name(code,    lc, uc, base, region, lname, cname) {
      if (code in specials) return specials[code]
      if (match(code, /_/)) {
        base   = substr(code, 1, RSTART-1)
        region = substr(code, RSTART+1)
      } else {
        base = code; region = ""
      }
      sub(/[.@].*/, "", base)
      sub(/[.@].*/, "", region)
      lname = (base in langs) ? langs[base] : base
      if (region == "") return lname
      cname = (region in countries) ? countries[region] : region
      return lname " (" cname ")"
    }

    # Right-pad string s to at least n characters (ASCII keys only, so safe).
    function rpad(s, n,    r) { r = s; while (length(r) < n) r = r " "; return r }

    # Strip leading and trailing newlines from a string (portable, no regex alternation).
    function strip_newlines(s,    l) {
      while (length(s) > 0 && substr(s, 1, 1) == "\n") s = substr(s, 2)
      l = length(s)
      while (l > 0 && substr(s, l, 1) == "\n") { l--; s = substr(s, 1, l) }
      return s
    }

    # Parse all PO header fields and emit a scannable aligned key-value list.
    # Does NOT print a trailing blank line — caller controls spacing via n_out.
    function emit_header(raw,    lns, n, i, col, k, v, nf, maxlen, hkeys, hvals) {
      n = split(raw, lns, "\n")
      nf = 0; maxlen = 0
      for (i = 1; i <= n; i++) {
        col = index(lns[i], ": ")
        if (col == 0) continue
        k = substr(lns[i], 1, col-1)
        v = substr(lns[i], col+2)
        sub(/\\n$/, "", v)
        hkeys[++nf] = k
        hvals[nf] = v
        if (length(k) > maxlen) maxlen = length(k)
      }
      for (i = 1; i <= nf; i++)
        printf "  %s%s%s  %s%s%s\n", ck, rpad(hkeys[i], maxlen), cr, cv, hvals[i], cr
    }

    # Print a translation pair with language labels:
    #   en  source text
    #   el  translation text
    # Labels are right-padded to lw chars; continuation lines align under content.
    # cs (source color) applies to src_label + source text.
    # ca (translation-label accent) applies to trn_label; ct to translation text.
    function emit_pair(src, trn,    n_s, n_t, src_lines, trn_lines, i) {
      n_s = split(src, src_lines, "\n")
      n_t = split(trn, trn_lines, "\n")
      printf "  %s%s%s%s  %s%s%s\n", cs, src_label, pad_src, cr, cs, src_lines[1], cr
      for (i = 2; i <= n_s; i++)
        printf "%s%s%s%s\n", cont_pad, cs, src_lines[i], cr
      printf "  %s%s%s%s  %s%s%s\n", ca, trn_label, pad_trn, cr, ct, trn_lines[1], cr
      for (i = 2; i <= n_t; i++)
        printf "%s%s%s%s\n", cont_pad, ct, trn_lines[i], cr
    }

    {
      t = index($0, "\t")
      if (t == 0) next
      ri = substr($0, 1, t-1)
      rs = substr($0, t+1)
      mid = junesc(substr(ri, 2, length(ri)-2))
      mst = junesc(substr(rs, 2, length(rs)-2))

      if (mid == "" && !inc_meta) next
      if (mst == "") next

      if (mid == "") {
        if (n_out > 0) printf "\n"
        emit_header(mst)
        n_out++
        next
      }

      # Skip msgctxt entries (contain \004 separator) — no jargon in human mode
      if (index(mid, "\004") > 0) next

      mid = strip_newlines(mid)
      mst = strip_newlines(mst)

      if (n_out > 0) printf "\n"
      emit_pair(mid, mst)
      n_out++
    }
    END { }
  '
}

